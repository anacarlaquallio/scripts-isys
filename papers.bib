@CONFERENCE{Chen2023,
	author = {Chen, Shi and Jiang, Ming and Zhao, Qi},
	title = {What Do Deep Saliency Models Learn about Visual Attention?},
	year = {2023},
	journal = {Advances in Neural Information Processing Systems},
	volume = {36},
	pages = {},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85190820870&partnerID=40&md5=7cd16f5af6ee34adf88feeaea9bb621b},
	affiliations = {University of Minnesota Twin Cities, Department of Computer Science and Engineering, Minneapolis, MN, United States},
	abstract = {In recent years, deep saliency models have made significant progress in predicting human visual attention.However, the mechanisms behind their success remain largely unexplained due to the opaque nature of deep neural networks.In this paper, we present a novel analytic framework that sheds light on the implicit features learned by saliency models and provides principled interpretation and quantification of their contributions to saliency prediction.Our approach decomposes these implicit features into interpretable bases that are explicitly aligned with semantic attributes and reformulates saliency prediction as a weighted combination of probability maps connecting the bases and saliency.By applying our framework, we conduct extensive analyses from various perspectives, including the positive and negative weights of semantics, the impact of training data and architectural designs, the progressive influences of fine-tuning, and common failure patterns of state-of-the-art deep saliency models.Additionally, we demonstrate the effectiveness of our framework by exploring visual attention characteristics in various application scenarios, such as the atypical attention of people with autism spectrum disorder, attention to emotion-eliciting stimuli, and attention evolution over time.Our code is publicly available at https://github.com/szzexpoi/saliency_analysis. © 2023 Neural information processing systems foundation. All rights reserved.},
	keywords = {Behavioral research; Deep neural networks; Semantics; Failure patterns; Fine tuning; Human visual attention; Implicit features; Learn+; Probability maps; Saliency modeling; Semantic attribute; Training data; Visual Attention; Forecasting},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
