@CONFERENCE{Santos2024520,
	author = {Santos, Laura and Carvalho, Bernardo B. and Barata, Catarina and Santos-Victor, José},
	title = {Extending 3D Body Pose Estimation for Robotic-Assistive Therapies of Autistic Children},
	year = {2024},
	journal = {Proceedings of the IEEE RAS and EMBS International Conference on Biomedical Robotics and Biomechatronics},
	pages = {520 - 525},
	doi = {10.1109/BioRob60516.2024.10719777},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85208629723&doi=10.1109%2FBioRob60516.2024.10719777&partnerID=40&md5=caa2690e076cd747c4cced7a12398bbb},
	affiliations = {Instituto Superior Técnico, Lisbon, Lisbon, Portugal; Politecnico di Milano, Information and Bioengineering, Milan, MI, Italy},
	abstract = {Robotic-assistive therapy has demonstrated very encouraging results for children with Autism. Accurate estimation of the child's pose is essential both for human-robot interaction and for therapy assessment purposes. Non-intrusive methods are the sole viable option since these children are sensitive to touch. While depth cameras have been used extensively, existing methods face two major limitations: (i) they are usually trained with adult-only data and do not correctly estimate a child's pose, and (ii) they fail in scenarios with a high number of occlusions. Therefore, our goal was to develop a 3D pose estimator for children, by adapting an existing state-of-the-art 3D body modelling method and incorporating a linear regression model to fine-tune one of its inputs (the focal length), thereby correcting the pose of children's 3D meshes. In controlled environments, our method maintains an error under 0.3m, which is deemed acceptable for this application. Additionally, it achieves lower error rates than current state-of-the-art methods while being more computationally efficient in terms of processed frames per second. In real-world scenarios, the proposed model performs comparably to a Kinect depth camera and successfully estimates 3D body poses in a significantly higher number of frames. © 2024 IEEE.},
	keywords = {3D reconstruction; Arthroplasty; Assistive technology; Digital elevation model; Linear regression; Microrobots; Nanorobots; Accurate estimation; Assistive; Autistic children; Body pose estimation; Children with autisms; Depth camera; Humans-robot interactions; Non-intrusive method; Pose estimators; Therapy assessment; Human robot interaction},
