	title = {Game Therapy for Specially-Abled Individuals with PPO Reinforcement Learning in VR-based Educational Games},
	year = {2024},
	pages = {1126 - 1133},
	doi = {10.1109/ICDICI62993.2024.10810847},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85216658031&doi=10.1109%2FICDICI62993.2024.10810847&partnerID=40&md5=aad8c451fbd08994dbb2584e0414ae04},
	affiliations = {Saveetha School of Engineering, Department of Computer Science and Engineering, Chennai, TN, India; Panimalar Engineering College, Department of Computer Science and Engineering, Chennai, TN, India; Sathyabama Institute of Science and Technology, Chennai, TN, India},
	abstract = {This research study presents a new application of reinforcement learning (RL), specifically Proximal Policy Optimization (PPO), in creating immersive virtual reality (VR) games aimed at aiding skill acquisition and emotional regulation for individuals with anger management difficulties. People with Down syndrome, Autism Spectrum Disorder, Cerebral Palsy (CP), Intellectual Disabilities (ID), and Stroke Survivors are mainly considered. The study examines how PPO-trained agents improve cognitive, social, and emotional regulation. Techniques include thorough hyperparameter optimization for the PPO algorithm with two sets. Iterative agent training in Unity and AWS Sagemaker uses cloud computing resources for parallelized training. Emotional regulation and positive behaviour change are assessed empirically and through user studies. Virtual reality (VR) cooperative RL games may offer comprehensive treatments for anger management, according to the results, which show promising gains in emotional regulation and teamwork. By enhancing interest and effectiveness in satisfying emotional regulation demands, the study demonstrates that AI-driven therapies and "gamified therapy,"which mixes game components into therapy, can revolutionize mental health. © 2024 IEEE.},
	author_keywords = {Air Hockey; Down Syndrome; Game therapy; Proximal Policy Optimization; Reinforcement Learning in therapy; Unity 3D; Virtual Reality},
	keywords = {Adversarial machine learning; Virtual environments; Virtualization; Air hockeys; Down's syndrome; Educational game; Game therapy; Policy optimization; Proximal policy optimization; Reinforcement learning in therapy; Reinforcement learnings; Research studies; Unity 3d; Reinforcement learning},
