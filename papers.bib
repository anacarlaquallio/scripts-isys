@CONFERENCE{Vasilyeva202535,
	author = {Vasilyeva, Ksenia S. and Guzelbaeva, Guzel Ya and Boltushkin, Anton A.},
	title = {ASD (Autistic Spectrum Disorder) Preschool Children Socialization Using Experimental Monitored Virtual Environments},
	year = {2025},
	pages = {35 - 40},
	doi = {10.1109/SmartIndustryCon65166.2025.10986081},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105007151873&doi=10.1109%2FSmartIndustryCon65166.2025.10986081&partnerID=40&md5=46bdf5582430049b036f4c35dc46d8a1},
	affiliations = {Kazan Federal University, Institute of Information Technology and Intelligent Systems, Kazan, Tatarstan Republic, Russian Federation},
	abstract = {The paper presents the development and testing of a virtual reality (VR) application for the development of social skills in preschool children with autistic spectrum disorders (ASD). The application includes a system of adaptive learning scenarios based on traditional methods of working with children with ASD, an interactive virtual assistant with an advanced navigation system and based on hand gesture recognition. Special attention was paid to the development of an automatic report generation system based on the Childhood Autism Rating Scale (CARS), which analyses more than 10 different parameters of user interaction with the virtual environment to track the dynamics of the condition. These reports form the basis for analysing user interaction with the virtual environment, which is especially important for the therapy of children with ASD, as it allows to adapt the training methodology to the individual characteristics of each child and adjust the therapeutic process based on objective progress indicators. The network interaction possibility was implemented to control the therapy process in real time, including visualisation of the user's movement trajectory and analysis of the visited zones of the virtual space. Initial testing was carried out on a control group of three normotypical 4-5 year old children to collect reference values of interaction with the virtual environment. © 2025 IEEE.},
	author_keywords = {autistic spectrum disorder; social skills; therapy; virtual reality},
	keywords = {Emotional intelligence; Sociology; Virtual environments; Adaptive learning; Autistic spectrum disorders; Development and testing; Learning scenarios; Preschool children; Scenario-based; Social skills; Therapy; User interaction; Virtual assistants; Virtualization},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
