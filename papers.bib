	affiliations = {Kalasalingam Academy of Research and Education, Department of Computer Science and Engineering, Krishnankoil, TN, India},
	abstract = {Autism and spectrum disorder is a developmental disability that is identified among children primarily between the 4–12 age groups. The number of children affected by this condition grows every year. Since there is no primary treatment for this illness, the only way to manage and control the increasing rate is through early intervention of this disorder with an effective assessment technique. As a result, improving performance through the simple straight application of conventional classification methods is not possible; instead, performance needs to be targeted and increased. In order to create a deep learning classification model for early intervention of ASD, this research proposes a mixed convolutional neural network and transfer learning algorithm. First, dimensionality reduction strategies employ backward feature deletion and forward feature formation. Utilizing both combined reduction strategies significantly raises the accuracy rate. Second, using the initial dataset and the pre-existing labeled dataset, a neural network model is built, and model migration rules are established. To finish building the classification model, a modest number of labeled target datasets are employed in the training. The integrated dataset is utilized to classify and predict the three key classification lists, including Dyslexia, Pervasive Development Disorder, and Asperger's syndrome, using the suggested approach based on model migration and hybrid deep learning models. The improved accuracy of the results of performing probabilities with the sample data has been predicted using k-fold cross-validation. The outcomes of the trial demonstrate that our assessment metrics with our proposed method, the accuracy of 88.56%, precision, and recall have improved, demonstrating the effectiveness of our method. © 2023, The Author(s), under exclusive license to Springer Nature Singapore Pte Ltd.},
	author_keywords = {Autism and spectrum disorder; Classification of disability; Deep transfer learning; Early intervention},
	keywords = {Convolutional neural networks; Deep learning; Diseases; Learning algorithms; Learning systems; Neural network models; Transfer learning; Autism and spectrum disorder; Classification models; Classification of disability; Deep transfer learning; Early intervention; Learning techniques; Model migrations; Reduction strategy; Spectra's; Classification (of information)},
	correspondence_address = {K. Abirami; Department of Computer Science and Engineering, Kalasalingam Academy of Research and Education, Krishnankoil, Tamil Nadu, India; email: k.abirami@klu.ac.in},
	editor = {Noor, A. and Saroha, K. and Pricop, E. and Sen, A. and Trivedi, G.},
