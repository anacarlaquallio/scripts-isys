	title = {Technological Tools for Assisting People with Autism Spectrum Disorder (ASD), Intellectual Development Disorder (IDD) and Physical Disabilities (PD): Developing a technological tool that assists people with different disabilities or disorders to help their personal autonomy},
	year = {2023},
