	author = {Sorbello, Katrina and Rojas, Luis A. and Salas, José and Chavarriaga, Enrique},
	title = {A Mobile Application to Dynamically Design Activities to Promote Personal Autonomy in Children with Autism Spectrum Disorder: A Usability Evaluation},
	year = {2023},
	journal = {Lecture Notes in Computer Science},
