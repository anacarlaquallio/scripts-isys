	doi = {10.1007/978-3-031-77571-0_3},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85214197326&doi=10.1007%2F978-3-031-77571-0_3&partnerID=40&md5=270eae56acd34db4a108f540c2c4846b},
	affiliations = {Université du Québec à Chicoutimi, Chicoutimi-Jonquiere, QC, Canada},
	abstract = {Individuals with Intellectual Disabilities (ID), Autism Spectrum Disorder (ASD), or Physical Disabilities (PD) experience significant impairments that limit their daily activities and challenge their autonomy. Enhancing their ability to live independently can substantially improve their well-being and that of their families. Assistive technologies offer promising solutions to facilitate this independence. However, current research in this field rarely addresses the specific needs of these individuals. Moreover, very few studies involve the targeted individuals in the development process of tools through a co-creation process. In this paper, we introduce a new smartphone application designed to support individuals with ID, ASD, and PD. The tool was developed in collaboration with users and caregivers and aimed at promoting social participation. The application was developed through several iterative cycles with targeted users in the loop. We then conducted a field study with ID, ASD, and PD participants to evaluate our tool. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2024.},
