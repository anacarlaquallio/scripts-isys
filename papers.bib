	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105012113163&doi=10.1109%2FOTCON65728.2025.11070486&partnerID=40&md5=22fb21290f07f2c6578be13f515f340a},
	affiliations = {Vishwakarma Institute of Technology, Pune, MH, India},
	abstract = {Detection of autism spectrum disorder (ASD) can significantly enhance intervention outcomes. This study proposes a novel approach to ASD detection using video analysis and machine learning techniques. Our method leverages real-time eye movement data captured via OpenCV to monitor and analyze pupil coordinates. Two types of data, one scanline path of the eyes are extracted and the second is 5 parameters that track the eye's movement in the area of interest is calculated. The first data is passed to the ResNet model and the second to the RandomForest model to detect potential signs of autism. The results of the classification are displayed to provide immediate feedback. We received 93% accuracy for the ResNet80 model and 95% for the Random Forest model. Our approach aims to offer a non-invasive, accessible tool for early autism detection, with potential applications in both clinical settings and everyday environments © 2025 IEEE.},
