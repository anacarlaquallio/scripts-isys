	year = {2024},
	journal = {Communications in Computer and Information Science},
	volume = {2169 CCIS},
	pages = {29 - 43},
	doi = {10.1007/978-3-031-68302-2_3},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85203145552&doi=10.1007%2F978-3-031-68302-2_3&partnerID=40&md5=91612d4fbf5be51f81b8cae295252c10},
	affiliations = {Shifa Tameer-e-Millat University, Department of Software Engineering, Islamabad, Pakistan; The Superior University, Lahore, Lahore, Punjab, Pakistan; Johannes Kepler University Linz, Institute for Software Systems Engineering, Linz, Upper Austria, Austria; National University of Computer and Emerging Sciences Islamabad, Department of Software Engineering, Islamabad, Islamabad, Pakistan},
	abstract = {Agile software development (ASD) is a popular process in the software development industry due to its dynamic nature and ability to release software quickly. However, managing the requirements in the ASD context remains a challenging task. This is because frequent changes need to be accommodated in the iterations. Consequently. It is challenging to effectively handle the changes and trace the requirements among artifacts such as sub-user stories, tasks, models, code snippets, and test cases. On the other hand, semi-automated tool support and organizational issues further complicate the requirement management process. Motivated by this, we propose an automated ontology-based technique to address the above-mentioned challenges, which benefits requirements management in agile development. The proposed technique involves tracing requirements, ensuring ontology consistency using competency questions, prioritizing user stories based on business value, and estimating the effort required for each user story. We empirically assessed the performance of the proposed technique by comparing it with baseline approaches using IEEE standards. The attained results indicate that the proposed technique significantly outperforms the baseline approaches. We believe that the proposed technique provides a cost-effective solution for requirement traceability in ASD. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2024.},
	author_keywords = {Agile Software Development; Ontology; Requirement Traceability; Software Requirement Management},
	keywords = {Software design; Agile software development; Development industry; Dynamic nature; Ontology's; Ontology-based; Requirement management; Requirements traceability; Software requirements management; Traceability techniques; User stories; Ontology},
	correspondence_address = {S.U.R. Khan; Department of Software Engineering, Shifa Tameer-e-Millat University (STMU), Islamabad, Pakistan; email: saif_rehman.ssc@stmu.edu.pk},
	editor = {Moser, B. and Fischer, L. and Glock, A.-C. and Mayr, M. and Luftensteiner, S. and Mashkoor, A. and Sametinger, J.},
	publisher = {Springer Science and Business Media Deutschland GmbH},
