@ARTICLE{Abbas2024,
	author = {Abbas, Rana Tuqeer and Sultan, Kashif and Sheraz, Muhammad and Chuah, Teong Chee},
	title = {A Comparative Analysis of Automated Machine Learning Tools: A Use Case for Autism Spectrum Disorder Detection},
	year = {2024},
	journal = {Information (Switzerland)},
	volume = {15},
	number = {10},
	pages = {},
	doi = {10.3390/info15100625},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85207491595&doi=10.3390%2Finfo15100625&partnerID=40&md5=358cd02b816f619043cf8b1b62fe858d},
	affiliations = {Bahria University, Department of Software Engineering, Islamabad, Pakistan; Multimedia University, Centre for Wireless Technology, Cyberjaya, Selangor, Malaysia},
	abstract = {Automated Machine Learning (AutoML) enhances productivity and efficiency by automating the entire process of machine learning model development, from data preprocessing to model deployment. These tools are accessible to users with varying levels of expertise and enable efficient, scalable, and accurate classification across different applications. This paper evaluates two popular AutoML tools, the Tree-Based Pipeline Optimization Tool (TPOT) version 0.10.2 and Konstanz Information Miner (KNIME) version 5.2.5, comparing their performance in a classification task. Specifically, this work analyzes autism spectrum disorder (ASD) detection in toddlers as a use case. The dataset for ASD detection was collected from various rehabilitation centers in Pakistan. TPOT and KNIME were applied to the ASD dataset, with TPOT achieving an accuracy of 85.23% and KNIME achieving 83.89%. Evaluation metrics such as precision, recall, and F1-score validated the reliability of the models. After selecting the best models with optimal accuracy, the most important features for ASD detection were identified using these AutoML tools. The tools optimized the feature selection process and significantly reduced diagnosis time. This study demonstrates the potential of AutoML tools and feature selection techniques to improve early ASD detection and outcomes for affected children and their families. © 2024 by the authors.},
	author_keywords = {autism spectrum disorder; AutoML; KNIME; TPOT},
	keywords = {Adversarial machine learning; Contrastive Learning; Diagnosis; Feature Selection; Autism spectrum disorders; Automated machine learning; Automated machines; Konstanz information miner; Learning tool; Machine-learning; Optimization tools; Pipeline optimization; Tree-based; Tree-based pipeline optimization tool; Diseases},
	correspondence_address = {T.C. Chuah; Centre for Wireless Technology, Faculty of Engineering, Multimedia University, Cyberjaya, Selangor, 63100, Malaysia; email: tcchuah@mmu.edu.my},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
	language = {English},
	abbrev_source_title = {Information},
