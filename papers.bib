	affiliations = {Universitatea Babeș-Bolyai, Department of Clinical Psychology and Psychotherapy, Cluj Napoca, Cluj, Romania; Icahn School of Medicine at Mount Sinai, New York, NY, United States; University of Lincoln, Lincoln, Lincolnshire, United Kingdom; Universiteit Gent, Ghent, VOV, Belgium; Högskolan i Skövde, School of Informatics, Skovde, Vastra Gotaland, Sweden; Loughborough University, Department of Computer Science, Loughborough, Leicestershire, United Kingdom; Vrije Universiteit Brussel, Brussels, BRU, Belgium; Can Tho University, Can Tho, Viet Nam; Heriot-Watt University, Edinburgh, Scotland, United Kingdom; University of Plymouth, Centre for Robotics and Neural Systems, Plymouth, Devon, United Kingdom; University of Portsmouth, School of Computing, Portsmouth, Hampshire, United Kingdom; Human Machine Interac-tion, Paris, France; SoftBank Group Corp., Tokyo, Japan; Institut Dalle Molle D'intelligence Artificielle Perceptive, Martigny, VS, Switzerland; Donders Institute for Brain, Cognition and Behaviour, Nijmegen, Gelderland, Netherlands; Carnegie Mellon University Africa, Kigali, Rwanda; Linköpings Universitet, Linkoping, Östergötland, Sweden},
	abstract = {The use of social robots in therapy for children with autism has been explored for more than 20 years, but there still is limited clinical evidence. The work presented here provides a systematic approach to evaluating both efficacy and effectiveness, bridging the gap between theory and practice by targeting joint attention, imitation, and turn-taking as core developmental mechanisms that can make a difference in autism interventions. We present two randomized clinical trials with different robot-assisted therapy implementations aimed at young children. The first is an efficacy trial (n = 69; mean age = 4.4 years) showing that 12 biweekly sessions of in-clinic robot-assisted therapy achieve equivalent outcomes to conventional treatment but with a significant increase in the patients’ engagement. The second trial (n = 63; mean age = 5.9 years) evaluates the effectiveness in real-world settings by substituting the clinical setup with a simpler one for use in schools or homes. Over the course of a modest dosage of five sessions, we show equivalent outcomes to standard treatment. Both efficacy and effectiveness trials lend further credibility to the beneficial role that social robots can play in autism therapy while also highlighting the potential advantages of portable and cost-effective setups. © 2025 The Authors, some rights reserved; exclusive licensee American Association for the Advancement of Science.},
	keywords = {Diseases; Medical applications; Patient treatment; Robots; Teaching; Autism intervention; Autism spectrum disorders; Children with autisms; Developmental mechanisms; Joint attention; Mean ages; Robot-assisted therapies; Social robots; Theory and practice; Turn-taking; Cost effectiveness; attention; autism; child; controlled study; devices; female; human; male; preschool child; procedures; randomized controlled trial; robotics; therapy; treatment outcome; Attention; Autism Spectrum Disorder; Child; Child, Preschool; Female; Humans; Male; Robotics; Treatment Outcome},
	correspondence_address = {T. Ziemke; Department of Computer & Information Science, Linköping University, Linköping, Sweden; email: tom.ziemke@liu.se},
	publisher = {American Association for the Advancement of Science},
	pmid = {41442492},
