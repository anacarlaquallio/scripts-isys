	author = {Ma, Yulan and Cui, Weigang and Liu, Jingyu and Guo, Yuzhu and Chen, Huiling and Li, Yang},
	title = {A Multi-Graph Cross-Attention-Based Region-Aware Feature Fusion Network Using Multi-Template for Brain Disorder Diagnosis},
	year = {2024},
	journal = {IEEE Transactions on Medical Imaging},
	volume = {43},
