	doi = {10.1109/FNWF63303.2024.11028805},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009138490&doi=10.1109%2FFNWF63303.2024.11028805&partnerID=40&md5=4dc98f9cbde5ebe0891916e80e002402},
	affiliations = {Ira A. Fulton Schools of Engineering, Tempe, AZ, United States; Ingram School of Engineering, San Marcos, TX, United States},
	abstract = {The paper presents an Augmented Reality (AR) handwashing tool designed for children with Autism Spectrum Disorder (ASD), addressing the challenges these children face due to sensory sensitivities and difficulties with multistep processes. Traditional teaching methods often fall short for these children, and existing technologies do not integrate handwashing procedures with learning tools specifically for children with ASD. This study fills that gap by creating an AR application that offers an engaging, low-stress environment, simulating a school bathroom without common stressors like fluctuating water temperature and background noise. The AR tool uses visual-audio cues and gamified interactions to guide users. Results from surveys and a pilot study with participants aged 19 to 21 show the tool requires minimal physical and cognitive demand and helps generalize handwashing skills across different settings. Despite limitations due to differences in how neurotypical adults and children with ASD react to stimuli, the tool shows promise in effectively teaching hygiene skills, potentially aiding independence and health in children with ASD. © 2024 IEEE.},
