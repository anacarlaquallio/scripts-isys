	author = {Farajpour, Reza and Sarparast, Mojtaba and Adabi, Jafar and Rezanejad, Mohammad and Pouresmaeil, Edris},
	title = {Common Mode Voltage Elimination and Zero-Sequence Circulating Current Reduction of Parallel Back-to-Back Converters},
	year = {2026},
	journal = {IEEE Access},
	pages = {},
	doi = {10.1109/ACCESS.2025.3649536},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105026354786&doi=10.1109%2FACCESS.2025.3649536&partnerID=40&md5=9307c796d93342a0b760ac92596800b3},
	affiliations = {Babol Noshirvani University of Technology, Faculty of Electrical and Computer Engineering, Babol, Mazandaran, Iran; University of Mazandaran, Faculty of Electrical Engineering, Babolsar, Mazandaran, Iran; Aalto University, Department of Electrical Engineering and Automation, Espoo, Uusimaa, Finland},
	abstract = {Parallel back-to-back converters are highly demanded in many high-power applications such as adjustable speed drive (ASD) systems, which reduce harmonics and improve the power factor and reliability compared to single two-level converters. It is evident that common-mode voltage (CMV) is the root cause of many challenges in ASD systems, such as shaft voltage and bearing damage, which may reduce equipment lifespan. On the other hand, Zero Sequence Circulating Current (ZSCC) leads to an additional current of switches which increases power loss and decreases the current capacity of converters. Simultaneous reduction of these two critical issues has to be considered in any switching strategy. In this regard, this paper presents a switching strategy based on a modified three-level space vector modulation scheme, which completely eliminates the common-mode voltage (CMV = 0 V). Moreover, the proposed switching sequence keeps the ZSCC within a low-amplitude and fully symmetric ripple, ensuring controlled circulating-current behavior without requiring any additional hardware. The method also generates a three-level line voltage and achieves an input-current THD of 3.92%. The simulation and experimental results confirm the effectiveness of the proposed approach. © 2013 IEEE.},
	author_keywords = {3LSVM; Back-to-Back; Common Mode Voltage (CMV); Zero Sequence Circulating Current (ZSCC)},
	keywords = {3LSVM; Adjustable-speed drives; Back-to-back; Circulating current; Common mode voltage; Drive systems; Switching strategies; Zero sequence circulating current; Zero sequences; Power converters},
	correspondence_address = {E. Pouresmaeil; Aalto University, Department of Electrical Engineering and Automation, Espoo, 02150, Finland; email: edris.pouresmaeil@aalto.fi},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
