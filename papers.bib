@ARTICLE{Liang20255271,
	author = {Liang, Chuang and Silva, Rogers F. and Adali, Tülay and Jiang, Rongtao and Zhang, Daoqiang and Qi, Shile and Calhoun, Vince D.},
	title = {Confound Controlled Multimodal Neuroimaging Data Fusion and Its Application to Developmental Disorders},
	year = {2025},
	journal = {IEEE Transactions on Image Processing},
	volume = {34},
	pages = {5271 - 5284},
	doi = {10.1109/TIP.2025.3597045},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105013214900&doi=10.1109%2FTIP.2025.3597045&partnerID=40&md5=9faac99ce0cc519319143988a2b847d1},
	affiliations = {Nanjing University of Aeronautics and Astronautics, School of Artificial Intelligence, Nanjing, Jiangsu, China; Georgia State University, Tri-Institutional Center for Translational Research in Neuroimaging and Data Science (TReNDS), Atlanta, GA, United States; Emory University, Atlanta, GA, United States; College of Engineering and Information Technology, Baltimore, MD, United States; Yale School of Medicine, Department of Radiology and Biomedical Imaging, New Haven, CT, United States},
	abstract = {Multimodal fusion provides multiple benefits over single modality analysis by leveraging both shared and complementary information from different modalities. Notably, supervised fusion enjoys extensive interest for capturing multimodal co-varying patterns associated with clinical measures. A key challenge of brain data analysis is how to handle confounds, which, if unaddressed, can lead to an unrealistic description of the relationship between the brain and clinical measures. Current approaches often rely on linear regression to remove covariate effects prior to fusion, which may lead to information loss, rather than pursue the more global strategy of optimizing both fusion and covariates removal simultaneously. Thus, we propose 'CR-mCCAR' to jointly optimize for confounds within a guided fusion model, capturing co-varying multimodal patterns associated with a specific clinical domain while also discounting covariate effects. Simulations show that CR-mCCAR separate the reference and covariate factors accurately. Functional and structural neuroimaging data fusion reveals co-varying patterns in attention deficit/hyperactivity disorder (ADHD, striato-thalamo-cortical and salience areas) and in autism spectrum disorder (ASD, salience and fronto-temporal areas) that link with core symptoms but uncorrelate with age and motion. These results replicate in an independent cohort. Downstream classification accuracy between ADHD/ASD and controls is markedly higher for CR-mCCAR compared to fusion and regression separately. CR-mCCAR can be extended to include multiple targets and multiple covariates. Overall, results demonstrate CR-mCCAR can jointly optimize for target components that correlate with the reference(s) while removing nuisance covariates. This approach can improve the meaningful detection of reliable phenotype-linked multimodal biomarkers for brain disorders. © 1992-2012 IEEE.},
	author_keywords = {Confounding covariate regression; global strategy; neurodevelopmental disorders; supervised multimodal fusion},
	keywords = {Brain; Data handling; Diseases; Functional neuroimaging; Attention deficit hyperactivity disorder; Autism spectrum disorders; Clinical measure; Confounding covariate regression; Covariates; Global strategies; Multi-modal; Multi-modal fusion; Neurodevelopmental disorder; Supervised multimodal fusion; Regression analysis; adolescent; algorithm; attention deficit hyperactivity disorder; autism; brain; child; diagnostic imaging; female; human; male; multimodal imaging; neuroimaging; nuclear magnetic resonance imaging; procedures; Adolescent; Algorithms; Attention Deficit Disorder with Hyperactivity; Autism Spectrum Disorder; Child; Female; Humans; Magnetic Resonance Imaging; Male; Multimodal Imaging; Neuroimaging},
	correspondence_address = {D. Zhang; Nanjing University of Aeronautics and Astronautics, Key Laboratory of Brain-Machine Intelligence Technology, Ministry of Education, Department of Artificial Intelligence, Nanjing, 211106, China; email: dqzhang@nuaa.edu.cn; S. Qi; Nanjing University of Aeronautics and Astronautics, Key Laboratory of Brain-Machine Intelligence Technology, Ministry of Education, Department of Artificial Intelligence, Nanjing, 211106, China; email: shile.qi@nuaa.edu.cn},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
