@CONFERENCE{Salido O202491,
	author = {Salido O, Martin G. and Borrego, Gilberto and Rodríguez, Luis Felipe},
	title = {Enhancing Emotional and Performance Data Collection for Agile Software Engineers: A Continuous Strategy Implementation},
	year = {2024},
	pages = {91 - 100},
	doi = {10.1109/CONISOFT63288.2024.00022},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85216815044&doi=10.1109%2FCONISOFT63288.2024.00022&partnerID=40&md5=62dc733e616172ba51d6aa18e46763b7},
	affiliations = {Instituto Tecnológico de Sonora, Departamento de Computación y Diseño, Ciudad Obregon, SON, Mexico},
	abstract = {Agile Software Development (ASD) has become the industry standard, facilitating rapid delivery of high-quality software by prioritizing flexible, iterative processes and the interactions of agile software engineers over rigid procedures. Hence, the performance assessment of agile software engineers should consider their emotions. In this study, we aim to take the first steps toward implementing a strategy for collecting affective and performance data using biometric devices and project tracking tools through a mixed-methods study. First, we analyzed interviews on emotions and performance metrics among local agile software engineers. Second, we conducted a quantitative analysis using emotional data tools and a project tracking tool (Jira) with software engineering students on a local company project. Results indicated (i) the most experienced emotions of agile software engineers, (ii) the most used metrics to assess their performance, (iii) the discrepancy between self-assessments and biometric measurements, and (iv) the relationship between stress, emotions, and task progression in projects. Future research should aim to enhance emotional data collection strategies to reduce complexity and improve response rates, providing better insights into the emotions-performance dynamic in agile environments. © 2024 IEEE.},
	author_keywords = {Agile; Biometric; Emotions; Software Engineer's Performance},
	keywords = {Computer aided software engineering; Computer software selection and evaluation; Software design; Agile; Agile software development; Agile softwares; Data collection; Emotion; Performance; Performance data; Project tracking; Software engineer performance; Strategy implementations; Software quality},
	correspondence_address = {M.G. Salido; Instituto Tecnológico de Sonora, Departamento de computación y diseño, Mexico; email: marting.salido@potros.itson.edu.mx},
	editor = {Juarez-Ramirez, R. and Fernandez y Fernandez, C.A. and Jimenez Calleros, S.P. and Ramirez-Noriega, A. and Guerra-Garcia, C.A. and Sandoval, G.L. and Menendez-Ortiz, M.A. and Hernandez-Ocharan, J.O.},
