@CONFERENCE{Zhou20251685,
	author = {Zhou, Yifan and Shi, Yuhu},
	title = {Study on the effectiveness of brain dynamic network clustering with standardized distances in space-time constraints},
	year = {2025},
	pages = {1685 - 1688},
	doi = {10.1109/ISCAIT64916.2025.11010547},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010218298&doi=10.1109%2FISCAIT64916.2025.11010547&partnerID=40&md5=2bdf798d8d97d2cb75e7c0a7f361b6ad},
	affiliations = {Shanghai Maritime University, College of Information Engineering, Shanghai, China},
	abstract = {In order to solve the problem that the traditional clustering method in dynamic functional connection (DFC) analysis is sensitive to data distribution and ignores the continuity of time series, this paper proposes an improved clustering effectiveness evaluation framework based on spatiotemporal characteristics. Firstly, the Standardized Corrected Distance (NCD) was designed to replace the Euclidean measure, and the distance weight was dynamically adjusted by the standard deviation of the feature dimension to solve the problem of BOLD signal scale difference in multiple brain regions. Secondly, the penalty term for state transition between sliding windows was introduced to construct the spatiotemporal joint optimization objective function to constrain the physiological rationality of state switching in the brain network. The reconstruction of the evaluation function is further integrated to improve the stability of the optimal clustering number selection. In the SimTB simulation data test, the accuracy of the proposed method in the three-classification and five-classification tasks reaches 84% and 80%, which is improved compared with the traditional method, and the variance of state dwell time variation is reduced. Empirical studies based on ASD autism dataset show that the accuracy of health and disease classification is higher when the optimal cluster number k=4. This method provides a more reliable dynamic connectivity quantification tool for the study of brain disease heterogeneity, and shows potential application value in the analysis of dynamic functional connectivity in the diagnosis of brain diseases. © 2025 IEEE.},
	author_keywords = {clustering effectiveness; dynamic functional connectivity; fmri; k-means},
	keywords = {Brain; Classification (of information); Cluster analysis; Clustering algorithms; Computer aided diagnosis; Diseases; Function evaluation; Optimization; Signal processing; Time series analysis; Brain disease; Brain dynamics; Clustering effectiveness; Clusterings; Dynamic functional connectivity; Dynamic network; Fmri; Functional connectivity; K-means; Network Clustering; Scales (weighing instruments)},
