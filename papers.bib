@CONFERENCE{Bindhu2024,
	author = {Bindhu, A. and Mol, Audrey Sruthi and Ravi, T. and Bodkhe, Rajesh G. and Safori, Amjad Omar and Vijayalakshmi, S.},
	title = {An Internet of Things Assisted Autism Spectrum Disorder Prediction Using Deep Learning Principles with Medical Image Processing Assistance},
	year = {2024},
	pages = {},
	doi = {10.1109/ICSES63760.2024.10910463},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105001416847&doi=10.1109%2FICSES63760.2024.10910463&partnerID=40&md5=c9fdd6801b9a35489a21ddae66276f2e},
	affiliations = {Infant Jesus College of Arts and Science for Women, Department of Computer Science, Mulagumoodu, India; Sathyabama Institute of Science and Technology, Department of Electrical & Computer Engineering, Chennai, TN, India; Yeshwantrao Chavan College of Engineering, Department of Mechanical Engineering, Nagpur, MH, India; RMK Engineering College, Department of Electronics and Communication Engineering, Kavaraipettai, TN, India; Zaraa University, Department of Journalism and Digital Media, Jordan; University of Business and Technology, Jeddah, Makkah, Saudi Arabia},
	abstract = {Characteristics of the complex neuro-developmental condition Autism Spectrum condition (ASD) include impaired social communication and restricted, repetitive patterns of behavior. This study presents a novel approach for identifying ASD in young infants by integrating deep learning, Internet of Things (IoT) and medical image processing. The goal of this research is to create comprehensive and discriminative features by combining wearable sensor data with brain imaging and smart home environments. For the greatest results, early diagnosis is essential. The proposed method called IoT based Autism Predictive Framework (IoTAPF) has a high detection rate of 97.8% and is cross-validated against the current Learning based Autism Detection Strategy (LADS). The proposed approach aims at improving diagnostic specificity which helps in forecasting behaviors and thus pushing earlier interventions, providing better support for ASD individuals and their families. The paper discusses the design and implementation of the framework, including sensor integration, data management, and predictive modeling. Preliminary results from pilot studies are presented, demonstrating the framework's potential to improve diagnostic accuracy and support individualized care plans. The proposed solution represents a significant advancement in the application of IoT technology for early autism detection and management, paving the way for more proactive and data-driven approaches in the field of neuro-developmental disorders. © 2024 IEEE.},
	author_keywords = {Autism Spectrum Disorder; IoT; IoTAPF; LADS; Medical Image Processing; Predictive Modeling; Wearable Sensors},
