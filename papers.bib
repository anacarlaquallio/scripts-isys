	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189914408&doi=10.1109%2FICAICCIT60255.2023.10466085&partnerID=40&md5=6187177da8e43b6cb8d598d3bfe203e0},
	affiliations = {Manav Rachna International Institute of Research and Studies, Faridabad, HR, India},
	abstract = {Autism is a complex neuro developmental disorder that affects the way a person communicates, relates to others, and processes information. It is characterized by difficulties with social skills, verbal and non-verbal communication, and repetitive behaviors. The examined papers evince conspicuous gaps, notably in the absence of curative implementations and a marked deficiency in achieving optimal machine learning accuracy. Regrettably, their scope remained confined to the domain of autism detection, with a notable oversight in addressing post-detection therapeutic interventions for individuals affected by autism. This paper endeavors to underscore the imperative for an efficacious platform designed to facilitate the catharsis of emotions experienced by individuals afflicted by Autism Spectrum Disorder (ASD). Through the utilization of emotion-centric technologies such as Image Recognition, coupled with a user-friendly mobile application interface, substantial challenges can be ameliorated by means of early detection, followed by constructive dialogue facilitated by dedicated conversational modules integrated within the application framework. © 2023 IEEE.},
