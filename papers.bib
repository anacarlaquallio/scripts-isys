	note = {Cited by: 2}
}

@CONFERENCE{Tang2024,
	author = {Tang, Lingzi and Guo, Muhan and Zhang, Kuan and Pan, Younghwan},
	title = {A Study Based on User Behavior Models and Visual Immersion Strategies Exploring the Impact of Color in Digital Spaces on the Autism Community},
	year = {2024},
	journal = {Proceedings of SPIE - The International Society for Optical Engineering},
	volume = {13176},
	pages = {},
	doi = {10.1117/12.3029335},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85194880178&doi=10.1117%2F12.3029335&partnerID=40&md5=f58cc46c4dc569a53b6ca81a11964f29},
	affiliations = {Kookmin University, Department of Smart Experience Design, Seoul, South Korea; LuXun Academy of Fine Arts, Shenyang, Liaoning, China},
	abstract = {This study explores content optimization methods by analyzing the relationship between user behavior and visual characteristics in digital immersive spaces, aiming to optimize visual content through the analysis of user behavior data to meet user experience needs. Currently, there are up to 70 million people worldwide with autism. This research conducted three rounds of visual color experiments at the Zhongshan District Rehabilitation Center for Mental Disorders in Dalian, focusing on the color preferences and cognitive abilities of the autism community. By integrating user behavior models and visual immersion strategies, the goal is to optimize the digital space experience for individuals with autism. Firstly, we analyzed the visual preferences and behavioral responses of autistic users, especially their strong preferences for colors, finding that over 89.7% of the autistic population prefers yellow, which can significantly improve their comfort and satisfaction levels. Secondly, based on user behavior data, a modular visual immersion environment was established to observe the behavioral patterns of individuals with autism within this space. The study shows that combining visual immersion strategies and user behavior models can effectively enhance the experience of users with autism. This research not only provides practical strategies for designing digital spaces with color preferences friendly to individuals with autism but also expands the application range of visual immersion technology among special needs groups to enhance user immersion experience and meet their specific needs. © 2024 SPIE.},
	author_keywords = {Autism Spectrum Disorder; Color Preferences; Digital Spaces; User Behavior Analysis; Visual Immersion Strategies},
	keywords = {Behavioral research; Digital storage; Diseases; Image processing; Autism spectrum disorders; Color preferences; Digital space; Immersive; Optimization method; User behavior analysis; User behavior modeling; User behaviors; Visual content; Visual immersion strategy; Color},
