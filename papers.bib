@CONFERENCE{Sun2023,
	author = {Sun, Yutong and Lyv, Shu Qiang and Huang, Chunhao and Hou, Miaole},
	title = {An improved single constant Kubelka-Munk method for pigment unmixing of Chinese paintings},
	year = {2023},
	journal = {Proceedings of SPIE - The International Society for Optical Engineering},
	volume = {12705},
	pages = {},
	doi = {10.1117/12.2680174},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85170262041&doi=10.1117%2F12.2680174&partnerID=40&md5=0fe435c8ed1bb4dd74aa23c5f3a2a66b},
	affiliations = {Beijing University of Civil Engineering and Architecture, School of Geomatics and Urban Spatial Informatics, Beijing, China; Beijing Key Laboratory for Architectural Heritage Fine Reconstruction & Health Monitoring, Beijing, China; Unisplendour Software System Co. Ltd., Beijing, China},
	abstract = {Since the mineral pigments on the surface of Chinese paintings are small in particle size and the pigment layer is too thin to cover the paper completely, their spectral mixing often shows nonlinearity. In this paper, aimed to accurately estimate the different types of pigments abundance on the surface of Chinese paintings, we proposed an improved single-constant Kubelka-Munk (KM) method for pigments unmixing algorithm. First, we selected Malachite, Azurite and Cinnabar pigments and mixed them in pairs in different abundances. They were added glue and then painted on the rice paper to produce the samples. The spectra of pure pigments and their mixed samples were acquired by the instrument of ASD FieldSpec 4. Second, we calculated the absorption and scattering ratio of the samples, pure pigments and rice paper. The rice paper and pure pigments were regarded as endmembers together for the pigment layer is too thin to cover the paper completely. The abundances were figured out base on the Fully Constrained Least Squares (FCLS) method endmember. Third, the abundances for different pigment endmember were re-calculated after removing the paper endmember. The experimental results show that the improved single-constant KM method has higher unmixing accuracy compared with the traditional spectral unmixing methods, and has good prospects for the application of unmixing composite pigments on the surface of Chinese paintings. © COPYRIGHT SPIE. Downloading of the abstract is permitted for personal use only.},
	author_keywords = {Chinese paintings; composite pigments; KM method; spectral unmixing},
	keywords = {Least squares approximations; Painting; Pigments; Chinese paintings; Composite pigment; Endmembers; Kubelka-munk methods; Mineral pigments; Particles sizes; Spectral mixing; Spectral unmixing; Unmixing; Unmixing algorithms; Particle size},
	editor = {Xiao, L. and Xue, J.},
	publisher = {SPIE},
