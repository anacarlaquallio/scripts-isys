	author = {Tang, Yunbo and Huang, Weirong and Liu, Rongchang and Yu, Yuanlong},
	title = {Learning Interpretable Brain Functional Connectivity via Self-Supervised Triplet Network With Depth-Wise Attention},
	year = {2024},
	journal = {IEEE Journal of Biomedical and Health Informatics},
