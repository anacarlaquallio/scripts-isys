@CONFERENCE{Piazza2024,
	author = {Piazza, Caterina and Falivene, Anna and Pandurangan, Shalini and Rapella, Silvia and Dondena, Chiara and Riboldi, Elena Maria and Cantiani, Chiara and Riva, Valentina},
	title = {Application of Machine Learning Analysis of EEG Connectivity Data and Environmental Factors for the Identification of neurodevelopmental conditions},
