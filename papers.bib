@ARTICLE{Tang2026,
	author = {Tang, Chunhui and Zhao, Yi and Peng, Jiansheng and Xiao, Wenying and Wang, Yu},
	title = {ASD-pose: Adaptive sparse-to-dense point cloud reconstruction for category-level pose estimation},
	year = {2026},
	journal = {Neurocomputing},
	volume = {664},
	pages = {},
	doi = {10.1016/j.neucom.2025.132056},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105022845809&doi=10.1016%2Fj.neucom.2025.132056&partnerID=40&md5=ccd055ebe818ee8cec80c9cdce494e50},
	affiliations = {University of Shanghai for Science and Technology, School of Optical-Electrical and Computer Engineering, Shanghai, Shanghai, China; Hechi University, Guangxi, China; University of Shanghai for Science and Technology, Department of Cardiology, Shanghai, Shanghai, China},
	abstract = {Category-level pose estimation is a technique focused on estimating the pose and size of various instances within a given object category, with broad applications across multiple fields. However, significant shape variations among instances within specific categories present substantial challenges for models performing such estimation. To address this issue, we have developed an innovative method to enhance model performance, integrating geometric neighbor feature extraction, cross-modal feature fusion, and adaptive Normalized Object Coordinate Space (NOCS) sparse point cloud reconstruction techniques. Initially, neighboring point pair features are utilized to encode the geometric characteristics of the point cloud. Secondly, a cross-attention mechanism-based embedding fusion strategy is introduced to strengthen feature interaction between RGB images and point clouds, thereby adaptively embedding category-consistent features into local geometric features. Furthermore, by employing an adaptive keypoint query mechanism to select the most representative keypoints, the adaptive NOCS-based sparse point cloud reconstruction network performs point cloud reconstruction in NOCS. In addition to advanced model design, we propose a two-stage segmentation strategy that enhances the precision of object detection and improves overall segmentation quality. Initial pose and size parameters are obtained through Singular Value Decomposition (SVD) and keypoint features, and these parameters are further optimized using the Iterative Closest Point (ICP) algorithm. Experimental results demonstrate that our approach achieves a significant improvement in localization accuracy on the REAL275 and CAMERA25 datasets compared to existing methods. © 2025 Elsevier B.V.},
	author_keywords = {Cross-attention mechanism; Fusion; Object pose estimation; Point cloud; Point pair},
	keywords = {Embeddings; Geometry; Image segmentation; Iterative methods; Object detection; Object recognition; Search engines; Singular value decomposition; Attention mechanisms; Coordinate space; Cross-attention mechanism; Keypoints; Object coordinates; Object pose; Object pose estimation; Point pair; Point-clouds; Pose-estimation; Fusion reactions; article; controlled study; diagnosis; feature extraction; iterative closest point; nonhuman; singular value decomposition},
	correspondence_address = {Y. Wang; Department of Cardiology, Shidong Hospital Affiliated to University of Shanghai for Science and Technology, Shanghai, 200438, China; email: wangyushidonghos@163.com},
	publisher = {Elsevier B.V.},
	issn = {09252312},
	coden = {NRCGE},
	language = {English},
	abbrev_source_title = {Neurocomputing},
	type = {Article},
