@CONFERENCE{Baghavathi Priya2024,
	author = {Baghavathi Priya, S. and Priyanga, S. and Kamisetty, Sri Surya Shobith},
	title = {Enhanced Detection of Autism Spectrum Disorder Using ResNet: A Deep Learning Approach},
	year = {2024},
	pages = {},
	doi = {10.1109/ICDSNS62112.2024.10690847},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85206575233&doi=10.1109%2FICDSNS62112.2024.10690847&partnerID=40&md5=6e1ebcafb19cf26cd1de6866db4a1fae},
	affiliations = {Amrita Vishwa Vidyapeetham Chennai Campus, Vengal, TN, India},
	abstract = {Timely and accurate detection of autism spectrum disorder (ASD) is essential for initiating effective interventions and improving patient outcomes. ASD is a complex neurodevelopmental condition characterized by difficulties in social communication and repetitive behaviors. Conventional diagnostic methods are often labor-intensive, subjective, and resource-demanding. This proposed work introduces a novel approach harnessing deep learning and the ResNet (Residual Network) architecture for ASD prediction based on eye-tracking data. Eye movement trajectories collected from individuals with and without ASD were transformed into images, resulting in a dataset comprising 547 images (219 ASD, 328 non-ASD) with dimensions of 640x480 pixels. A pre-trained ResNet50 model was utilized, with modifications to its top layers for binary classification, employing the Adam optimizer, binary cross-entropy loss, and data augmentation techniques. Transfer learning was employed by fine-tuning the model on the training set. Comprehensive evaluation metrics including accuracy, loss curves, receiver operating characteristic (ROC) curve, and confusion matrix were computed. The results demonstrated outstanding performance, with the ResNet model achieving a validation accuracy of 95% and an area under the ROC curve (AUC) of 0.95. The confusion matrix further confirmed the model's robustness, accurately identifying 980 out of 1000 test samples as ASD cases. This proposed work underscores the remarkable efficacy of the ResNet architecture, in conjunction with transfer learning and data augmentation, for precise ASD prediction using eye-tracking data, offering promising implications for clinical applications and early interventions in ASD cases. © 2024 IEEE.},
	author_keywords = {Autism Spectrum Disorder (ASD); Binary Classification; Deep Learning; ResNet; Transfer Learning},
	keywords = {Deep learning; Diagnosis; Autism spectrum disorder; Autism spectrum disorders; Binary classification; Data augmentation; Disorder predictions; Eye-tracking; Residual network; Tracking data; Transfer learning; Diseases},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {9798350373110},
	language = {English},
	abbrev_source_title = {IEEE Int. Conf. Data Sci. Netw. Secur., ICDSNS},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

@CONFERENCE{Singh2024400,
	author = {Singh, Priya and Pathak, Abhishek and Ganai, Umer Jon and Bhushan, Braj and Subramanian, Venkatesh K.},
	title = {Video Based Computational Coding of Movement Anomalies in ASD Children},
	year = {2024},
	journal = {IEEE Computer Society Conference on Computer Vision and Pattern Recognition Workshops},
	pages = {400 - 409},
	doi = {10.1109/CVPRW63382.2024.00045},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85206477009&doi=10.1109%2FCVPRW63382.2024.00045&partnerID=40&md5=d8b8d5f12e51aa60b75c1106aba27ade},
	affiliations = {TCS Research, Mumbai, MH, India; Airbase Labs India Pvt Ltd, India; Indian Institute of Technology Kanpur, Kanpur, UP, India},
	abstract = {Autism spectrum disorder (ASD) is a neurodevelopmental disorder. Early detection and diagnosis are instrumental in early intervention, yet diagnosis often remains delayed due to the limited availability of clinical practitioners and specialists. We propose a Computer Vision and Machine Learning based novel framework for quantitative screening of autism spectrum disorder (ASD). This is aimed to minimize the need for trained professionals at the initial stage but not substitute for it. We designed simple activities in consultation with ASD clinical psychologists and therapists for children in the 3-7 years age group that could be performed in their natural environment (home). The temporal features extracted from these activities encode the behavioral differences between Autism Spectrum Disorder (ASD) and Typically Developing (TD) control groups. Due to the unavailability of a public dataset of children performing the designed task, we created our own video dataset of 210 videos taken in unconstrained natural settings. The dataset was collected from a single RGB camera. The proposed vision and learning-based algorithms extract features from the collected data for a comprehensive set of indicators including the visual attention span, name-calling response, neck pose of the subjects, gross motor movement and establish a parametrized automated protocol for early detection without the need to take the subjects out of their natural daily environment. This forestalls the possibility of mis-performance by the subject out of nervousness due to unfamiliar surroundings. Results show that our ASD screening methodology can achieve superior performance compared to the single phenotype approaches, and thus has a prognostic value that could be helpful for both clinical and research applications. © 2024 IEEE.},
	author_keywords = {Autism Spectrum Disorder; Computer Vision; Early detection of ASD; Machine Learning},
	keywords = {Adversarial machine learning; Clinical research; Contrastive Learning; Diagnosis; Autism spectrum disorders; Detection and diagnosis; Early detection of autism spectrum disorder; Early intervention; Machine-learning; Performance; Quantitative screening; Simple++; Vision learning; Diseases},
