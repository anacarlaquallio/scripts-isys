	title = {ASDEXPLAINER : An Interpretable Graph Neural Network Framework for Brain Network Based Autism Spectrum Disorder Analysis},
	year = {2023},
	pages = {},
	doi = {10.1109/ICCCNT56998.2023.10306963},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85179849314&doi=10.1109%2FICCCNT56998.2023.10306963&partnerID=40&md5=524a90f36a74c432adb37ba0d201de89},
	affiliations = {N S S College of Engineering, Palakkad, Department of Computer Science and Engineering, Akathethara, KL, India},
	abstract = {Understanding the predictions made by GNN models can lead to significant breakthroughs in trusting these models to be used for safety critical healthcare applications. GNNs are excellent at modeling non euclidean data such as graphs, but many scientists refrain from using them because of their blackbox nature. This is due to the ambiguity that exists regarding the background mechanisms that lead to predictions. Human brain can be effectively modeled as a graph, which is formally known as the brain network which is in turn used for studying interactions between various brain regions when it is affected by some disorder. Our work aims to conduct a comparative analysis among the explanations generated by various modified GNN explainability models for a pre-trained GNN model over Autism Spectrum Disorder (ASD) fMRI dataset. It mainly comprises 2 phases. The first being training a GNN model tailor-made for brain networks which highlights salient ROIs by using functional and structural information from fMRI. Secondly, the explanation generator that uses GNN explainability methods is modified specifically to suit brain network data to generate explanations about the predictions by discovering neurological biomarkers. We evaluate the performance of the explanation generator by employing various evaluation metrics. The obtained results show great correspondence with the ground truth explanations regarding the brain regions that get affected by autism. © 2023 IEEE.},
	author_keywords = {Autism Spectrum Disorder; Brain network; Explainability; functional Magnetic Resonance Imaging; Graph Neural Network},
	keywords = {Brain; Diseases; Functional neuroimaging; Graph neural networks; Magnetic resonance imaging; Safety engineering; Spectrum analysis; Autism spectrum disorders; Brain networks; Brain regions; Explainability; Functional magnetic resonance imaging; Health care application; Network frameworks; Network-based; Non-Euclidean; Forecasting},
	correspondence_address = {G.S. Menon; Nss College of Engineering, Department of Computer Science and Engineering, Palakkad, Kerala, India; email: gayathrismenon5@gmail.com; J. Poornima; Nss College of Engineering, Department of Computer Science and Engineering, Palakkad, Kerala, India; email: poornijaidip@gmail.com; A.T. Sojan; Nss College of Engineering, Department of Computer Science and Engineering, Palakkad, Kerala, India; email: aneenasojan@gmail.com; P.J. Mridhula; Nss College of Engineering, Department of Computer Science and Engineering, Palakkad, Kerala, India; email: mridhulapj@gmail.com; A. Mohan; Nss College of Engineering, Department of Computer Science and Engineering, Palakkad, Kerala, India; email: anurajmohan@gmail.com},
