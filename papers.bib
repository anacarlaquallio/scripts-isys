	issn = {18144225},
	language = {English},
	abbrev_source_title = {Radioelectron. Comp. Syst.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 5; All Open Access; Gold Open Access; Green Accepted Open Access; Green Open Access}
}

