	affiliations = {Yonsei University College of Medicine, Department of Integrative Medicine, Seoul, South Korea; Yonsei University, Department of Artificial Intelligence, Seoul, South Korea; Yonsei University College of Medicine, Department of Psychiatry, Seoul, South Korea; Ewha Womans University, Division of Mechanical and Biomedical Engineering, Seoul, Seoul, South Korea; Severance Hospital, Department of Child and Adolescent Psychiatry, Seoul, South Korea; Biomedical Research Institute, Seoul, South Korea; The Catholic University of Korea Eunpyeong St. Mary’s Hospital, Department of Psychiatry, Seoul, South Korea; The Catholic University of Korea Eunpyeong St. Mary’s Hospital, Department of Psychiatry, Seoul, South Korea; Wonkwang Medical Center, Department of Psychiatry, Iksan, Chonbuk, South Korea; Wonkwang University (WKU), School of Medicine, Department of Psychiatry, Iksan, Jeollabuk-do, South Korea; Seoul National University Bundang Hospital, Department of Psychiatry, Seongnam, Gyeonggi-do, South Korea; Seoul National University College of Medicine, Department of Psychiatry, Seoul, South Korea; Hanyang University College of Medicine, Department of Psychiatry, Seoul, South Korea; Hanyang University, Institute of Mental Health, Seoul, South Korea; Asan Medical Center, Department of Psychiatry, Seoul, Seoul, South Korea; Yonsei Clinic of Psychiatry, Seoul, Seoul, South Korea; Chungbuk National University Hospital, Department of Psychiatry, Cheongju-si, Chungcheongbuk-do, South Korea; The Catholic University of Korea Seoul St. Mary's Hospital, Department of Psychiatry, Seoul, South Korea; Yonsei University College of Medicine, Department of Neurosurgery, Seoul, South Korea; Seoul National University Hospital, Department of Psychiatry, Seoul, South Korea},
	abstract = {Early Autism Spectrum Disorder (ASD) identification is crucial but resource-intensive. This study evaluated a novel two-stage multimodal AI framework for scalable ASD screening using data from 1242 children (18–48 months). A mobile application collected parent-child interaction audio and screening tool data (MCHAT, SCQ-L, SRS). Stage 1 differentiated typically developing from high-risk/ASD children, integrating MCHAT/SCQ-L text with audio features (AUROC 0.942). Stage 2 distinguished high-risk from ASD children by combining task success data with SRS text (AUROC 0.914, Accuracy 0.852). The model’s predicted risk categories strongly agreed with gold-standard ADOS-2 assessments (79.59% accuracy) and correlated significantly (Pearson r = 0.830, p < 0.001). Leveraging mobile data and deep learning, this framework demonstrates potential for accurate, scalable early ASD screening and risk stratification, supporting timely interventions. © The Author(s) 2025.},
