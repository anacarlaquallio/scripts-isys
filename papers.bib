@CONFERENCE{Rocha2025485,
	author = {Rocha, Ines and Moreira, Ana Maria Diniz and Araújo, João and Liebel, Grischa},
	title = {Envisioning a Requirements Elicitation Method for Neurodivergent-Inclusive Software},
	year = {2025},
	journal = {Proceedings of the IEEE International Conference on Requirements Engineering},
	pages = {485 - 493},
	doi = {10.1109/RE63999.2025.00058},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105020011270&doi=10.1109%2FRE63999.2025.00058&partnerID=40&md5=3091d814095502a63fc3c61deeafa728},
	affiliations = {Universidade Nova de Lisboa, School of Science and Technology, Lisbon, Lisboa, Portugal; Reykjavík University, Department of Computer Science, Reykjavik, Iceland},
	abstract = {Neurodiversity, increasingly recognized in society, encompasses a range of neurological differences, including autism, ADHD, and dyslexia. In software engineering, addressing neurodiversity is crucial to designing accessible and inclusive products that accommodate diverse user needs. Despite growing interest, a clear understanding of how to create neurodivergent-inclusive software remains underdeveloped. To help bridge this gap, we developed a conceptual model that identifies key neurodivergent concepts and relationships to guide software requirements elicitation. This model was evaluated through a survey involving 100 participants, including 37 neurodivergent individuals. These initial evaluation results are encouraging and indicate the model has the potential to advance the creation of software accessible to neurodivergent users. Moreover, the survey also revealed several necessary improvements towards successful requirements elicitation support. To this end, we aim to ensure the completeness of the collected information and identify potential contradictions among accommodating strategies, as a foundation for developing concrete support tools for requirements elicitation. Based on the complete conceptual model, these tools will integrate into a dedicated elicitation method, built on top of traditional elicitation methods, such as focus groups or workshops, and will be further enhanced by a large language model-based assistant. These results will support requirements engineers to effectively elicit neurodivergent-inclusive requirements. © 2025 IEEE.},
	author_keywords = {accessibility; conceptual model; neurodiversity; requirements elicitation},
	keywords = {Computer software; Accessibility; Conceptual model; Concrete supports; Elicitation methods; Evaluation results; Neurodiversity; Requirements elicitation; Software requirements; Support tool; User need; Requirements engineering},
	correspondence_address = {I. Rocha; NOVA University of Lisbon, NOVA LINCS, School of Science and Technology, Monte da Caparica, Portugal; email: il.rocha@campus.fct.unl.pt; A. Moreira; NOVA University of Lisbon, NOVA LINCS, School of Science and Technology, Monte da Caparica, Portugal; email: amm@fct.unl.pt; J. Araujo; NOVA University of Lisbon, NOVA LINCS, School of Science and Technology, Monte da Caparica, Portugal; email: joao.araujo@fct.unl.pt},
