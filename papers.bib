	affiliations = {Nanjing University of Information Science & Technology, School of Computer Science, Nanjing, Jiangsu, China; Nanjing University of Chinese Medicine, School of Acupuncture-Moxibustion and Tuina, Nanjing, Jiangsu, China; Nanjing University of Chinese Medicine, School of Health Preservation and Rehabilitation, Nanjing, Jiangsu, China; Nanjing Medical University, Department of Rehabilitation Medicine, Nanjing, Jiangsu, China},
