@ARTICLE{Rathod2025266,
	author = {Rathod, Vijayalaxmi N. and Goudar, R. H.},
	title = {Harnessing Explainable AI for Next-Generation Autism Diagnosis and Severity Assessment},
	year = {2025},
	journal = {International Journal of Intelligent Engineering and Systems},
	volume = {18},
	number = {2},
	pages = {266 - 281},
	doi = {10.22266/IJIES2025.0331.21},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-86000307490&doi=10.22266%2FIJIES2025.0331.21&partnerID=40&md5=485c343869ff6ddb347f0a96677b6f31},
	affiliations = {Visvesvaraya Technological University, Department of Computer Science and Engineering, Belagavi, KA, India},
	abstract = {Autism Spectrum Disorder (ASD) diagnosis and intervention remain critical challenges due to the complex interplay of behavioural traits and the lack of definitive diagnostic tools. This study introduces an innovative Multilayer Perceptron (MLP) framework for ASD prediction and severity classification across diverse age groups—toddlers, children, adolescents, and adults—using non-clinical datasets from the Kaggle and UCI repositories. The dual-stage model integrates ASD classification and severity-level categorization (mild, moderate, and severe) while leveraging Explainable AI techniques, specifically SHapley Additive extensions (SHAP), to provide insights into feature importance. The model demonstrated exceptional performance, achieving an F1-score exceeding 0.97 in toddler and adult classifications and maintaining robust accuracy across all severity levels. Severity classification showed similar efficacy, with precision and recall exceeding 98% for toddlers and 96% for adults, significantly. The outperforming existing models include the stacked sparse autoencoder with a softmax classifier and salience network-based methods. SHAP analysis highlights key behavioural and demographic features across age groups and severity categories, underscoring the framework's potential to tailor interventions. This lightweight, scalable model bridges critical gaps in age-inclusive and nonclinical ASD diagnostics, offering a transformative solution for early detection and personalized care. Future work will refine the model's adaptability to real-world scenarios and explore cross-cultural applications. © (2025), (Intelligent Network and Systems Society). All rights reserved.},
	author_keywords = {Autism spectrum disorder (ASD); Behavioural screening; Explainable AI (XAI); Multilayer perceptron (MLP); Severity classification},
	correspondence_address = {R.H. Goudar; Department of Computer Science and Engineering, Visvesvaraya Technological University, Belagavi, Karnataka, 590018, India; email: rhgoudar.vtu@gmail.com},
