@CONFERENCE{Zhang2024684,
	author = {Zhang, Xinran and Qi, Guoyuan},
	title = {Application of Additive-State-Decomposition-Based Model-Compensation Controller in Compound Vertical Takeoff and Landing Unmanned Aircraft},
	year = {2024},
	pages = {684 - 689},
	doi = {10.1109/DDCLS61622.2024.10606784},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85202449995&doi=10.1109%2FDDCLS61622.2024.10606784&partnerID=40&md5=17c23b57528a9c4b0a7ab3b0967cbee4},
	affiliations = {Tiangong University, School of Control Science and Engineering, Tianjin, China},
	abstract = {The compound vertical take-off and landing (VTOL) unmanned aerial vehicle (UAV) is a complex nonlinear system characterized by strong coupling, high complexity, and sensitivity to external disturbances and model uncertainties. For a VTOL UAV, there are two main control modes: multi-rotor mode and fixed-wing mode. The completeness and accuracy of the control model should be considered; therefore, an observer is used to observe the model's uncertainty and external disturbances. Based on the idea of additive state decomposition (ASD), the high-order differentiator (HOD) and compensation function observer (CFO) are combined to design an ASD-based model compensation controller (ASD-MCC), which achieves tracking control for the primary system and stability control for the secondary system. The stability and convergence of the closed-loop system are proven. Using the complete model of the compound VTOL UAV, numerical simulations are conducted in MATLAB's Simulink platform to compare the proposed control algorithm with traditional PID control and model compensation control (MCC), verifying the superiority and effectiveness of the proposed algorithm. © 2024 IEEE.},
	author_keywords = {additive state decomposition; compensation function observer; compound; vertical take-off and landing},
	keywords = {Closed loop control systems; Compound helicopters; Control system stability; Proportional control systems; Three term control systems; Two term control systems; VTOL/STOL aircraft; Additive state decomposition; Aerial vehicle; Compensation controller; Compensation function observer; Compensation functions; Compound; External disturbances; Function observer; Model compensation; Vertical take-off and landings; Unmanned aerial vehicles (UAV)},
