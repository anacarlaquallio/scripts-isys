@ARTICLE{Krishnan202464599,
	author = {Krishnan, Kesavan and Jomhari, Nazean Z. and Ayyasamy, Ramesh Kumar and Abdul-Kareem, Sameem and Krishnan, Sathis},
	title = {A Framework for Developing Haptics Based Virtual Environment for Spatial Cognition Enhancement in Autistic People},
	year = {2024},
	journal = {IEEE Access},
	volume = {12},
	pages = {64599 - 64621},
	doi = {10.1109/ACCESS.2024.3397076},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85192955744&doi=10.1109%2FACCESS.2024.3397076&partnerID=40&md5=c277eaf3c60a10c38e44b02e43590ae4},
	affiliations = {Universiti Malaya, Faculty of Computer Science and Information Technology, Kuala Lumpur, Malaysia; Faculty of Information and Communication Technology (FICT) Kampar, Perak, Malaysia},
	abstract = {Autistic people typically need methodical support as they explore and interact with their immediate surroundings and the objects associated with them, emphasising the importance of spatial knowledge and cognitive skills in improving and understanding their surroundings. The objective of this research paper is to present a conceptual and technical framework that could be of significant assistance in developing spatial ability and cognitive skills in autistic people. This framework is constructed based on aspects of autistic behaviour, spatial cognition, and technical aspects of haptic technology and virtual environments (VEs). The framework uses the Model, View, Controller (MVC) pattern as its structural foundation. This paper highlights the important elements required for scholars and designers to create and develop a haptic-based virtual environment (HBVE) for autistic people in order to improve spatial knowledge and cognitive skills. Furthermore, this research also aimed to create an HBVE application based on the proposed framework in order to assess its effectiveness. This research paper evaluates the proposed framework based on end-user perspectives. The findings indicate that the experimental study conducted with autistic people has demonstrated notable progress in enhancing spatial knowledge and cognitive abilities among this population. The experimental implementation of these findings supports the developed framework's efficacy. © 2013 IEEE.},
