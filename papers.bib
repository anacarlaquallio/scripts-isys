	keywords = {Cost effectiveness; Errors; Hyperspectral imaging; Mean square error; Radiometry; Reflection; Remote sensing; Solar cells; Continuous monitoring; Crop growth; Digital image; Ground based; Growth status; Multi-spectral; Non-imaging; Non-imaging multi-spectral; Plant growth; Radiometric calibrations; Crops; crop plant; digital image; growth rate; remote sensing; satellite sensor},
