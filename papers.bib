	volume = {267},
	pages = {},
	doi = {10.1016/j.eswa.2024.126170},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85212592008&doi=10.1016%2Fj.eswa.2024.126170&partnerID=40&md5=be94fedb33f51458d69abf658dd6e68c},
	affiliations = {Anhui University, Key Laboratory of Intelligent Computing and Signal Processing, Hefei, Anhui, China; Anhui University, School of Computer Science and Technology, Hefei, Anhui, China},
	abstract = {Although Transformers achieve remarkable success in computer vision, their application to brain network classification faces challenges such as high computational complexity and limited global receptive fields, which hinder the capture of subtle spatiotemporal feature interactions. Additionally, contamination by physiological and external noise complicates the process, as the global attention mechanism incorporates noise, degrading model performance. Traditional methods rely on predefined thresholds, resulting in static network structures that cannot adaptively optimize during training or remove noise based on feature-driven changes. To address these challenges, Adaptive Graph Isomorphic Information Bottleneck Mamba (AGIIBM) is proposed as a novel framework for multi-view brain network classification. The Graph Information Bottleneck (GIB) is introduced to dynamically optimize the brain network structure by preserving essential information, filtering out irrelevant features, and minimizing redundancy. The Mamba module, combined with the Graph Isomorphism Network (GIN), is used to update node feature states adaptively, enhancing the spatiotemporal representations of brain nodes. AGIIBM is validated through extensive experiments on three datasets: the EEG-based CHB-MIT and Siena datasets for patient-specific analysis, and the fMRI-based ABIDE-I dataset for cross-patient analysis. The results show that AGIIBM outperforms state-of-the-art models in classification accuracy, computational efficiency, and generalization ability. This dynamic framework is considered a significant advancement in brain network analysis, with promising potential for clinical applications in epilepsy detection and autism classification. © 2024 Elsevier Ltd},
	author_keywords = {Brain network classification; Cross-patient; Dynamic brain network; Mamba; Patient-specific},
	keywords = {Brain network classification; Brain networks; Cross-patient; Dynamic brain network; Information bottleneck; Mamba; Multi-views; Network classification; Patient specific; Diseases},
	correspondence_address = {D. Sun; Key Laboratory of Intelligent Computing & Signal Processing, Ministry of Education, School of Artificial Intelligence, Anhui University, Hefei, 230601, China; email: sundengdi@163.com},
	publisher = {Elsevier Ltd},
