@ARTICLE{Pedram2025,
	author = {Pedram, Shiva and Piatkowski, Timothy M.},
	title = {Exploring the potential of virtual reality (VR) in mental healthcare: a systematic literature review},
	year = {2025},
	journal = {Virtual Reality},
	volume = {29},
