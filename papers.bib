	keywords = {Adversarial machine learning; Contrastive Learning; Deep learning; Diseases; Emotion Recognition; Face recognition; Attention mechanisms; Autism spectrum disorders; Customer experience; Emotion recognition; Facial emotion recognition; Facial emotions; Machine learning-based attention mechanism; Machine-learning; U-net; Convolutional neural networks},
