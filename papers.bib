@ARTICLE{Bera20251,
	author = {Bera, Arpita and Roy, Aviroop and Raut, Anjana and Samantaray, Swati},
	title = {Intelligent Approaches Towards Learning Disabilities},
	year = {2025},
	journal = {Lecture Notes in Networks and Systems},
	volume = {1363 LNNS},
	pages = {1 - 11},
	doi = {10.1007/978-981-96-5217-4_1},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105016015020&doi=10.1007%2F978-981-96-5217-4_1&partnerID=40&md5=f3f9bc568b06a3ed56b27419df91d8f1},
	affiliations = {Kalinga Institute of Industrial Technology, Bhubaneswar, Bhubaneswar, OR, India; Kalinga Institute of Industrial Technology, Bhubaneswar, School of Humanities, Bhubaneswar, OR, India},
	abstract = {Learning disabilities are a set of neurodevelopmental abnormalities that can seriously impair a person’s capacity to pick up new skills. Consequently, difficulties in speaking, reading, writing, focusing, comprehending information, recalling details, executing mathematical computations, or coordinating actions might be experienced. Artificial intelligence (AI) has evolved broadly in the modern technology on its approach to the crowning point of the today’s digital world, providing the appropriate way of solving problems. Smart applications have been identified as important ways of educating children with learning or speech disorders. Assistive technological aids provide individualized communication, help in prior detection and provide programmable treatment to those with cognitive dysfunction. The paper explores the critical impact of digital technology on the children’s standard of living with learning disabilities, delving into the current landscape, challenges, opportunities, and future directions. By examining the latest advancements tailored for individuals with learning disabilities, the paper aims to provide insights into how soft computing approaches can be harnessed to create inclusive learning environments and empower learners with diverse needs. © The Author(s), under exclusive license to Springer Nature Singapore Pte Ltd. 2025.},
	author_keywords = {Artificial intelligence (AI); Autism; Fuzzy logic; Learning disability; Machine learning; Virtual reality},
	keywords = {Artificial intelligence; Assistive technology; Computer aided instruction; E-learning; Learning systems; Signal processing; Soft computing; Autism; Digital world; Fuzzy-Logic; Learning disabilities; Machine-learning; Mathematical computation; Modern technologies; Smart applications; Speech disorders; Fuzzy logic; Virtual reality},
