@ARTICLE{Saleur2025,
	author = {Saleur, Carole and Luxembourger, Christophe H. and Tazouti, Youssef},
	title = {Contribution of an Educational Classroom App to Enhancing the Early Literacy and Numeracy of French Preschoolers With ASD},
	year = {2025},
	journal = {Journal of Special Education Technology},
	pages = {},
	doi = {10.1177/01626434251379818},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105016216079&doi=10.1177%2F01626434251379818&partnerID=40&md5=d08edf61391ab7d577f3a1cb126c7543},
	affiliations = {Laboratoire Lorrain de Psychologie et Neurosciences de la Dynamique des Comportements, Nancy, Grand Est, France},
	abstract = {Recent research suggests that educational apps can help children with ASD develop early literacy and numeracy skills, but only if they incorporate certain pedagogical features. AppL+ is an early literacy and numeracy app designed by a multidisciplinary team to meet these criteria. This is the first quasi-experimental study of the benefits of an early literacy and numeracy educational application conducted in preschools in France with children in inclusive education. The 36 children, aged 4–6 years, included in the study were divided into three experimental groups. Those in experimental group 1 used AppL+ during their lessons; those in experimental group 2 used AppL+ with slowed-down auditory stimuli, and those in the control group did not use AppL+. The experiment lasted 12 weeks. The results showed that students in experimental groups 1 and 2 performed better at the end of the experiment than those in the control group. In contrast, no significant differences were found between experimental groups 1 and 2, and the slowing down of auditory stimuli in AppL + had no impact. We discuss possible reasons for this result and explore other ways in which AppL + could be improved. © The Author(s) 2025},
	author_keywords = {ASD; early literacy; early numeracy; educational app; school inclusion},
