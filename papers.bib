	title = {Development of computer vision based assistive software for accurate analysis of autistic child stereotypic behavior},
	year = {2023},
	pages = {},
	doi = {10.1109/RAEEUCCI57140.2023.10134091},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85161585788&doi=10.1109%2FRAEEUCCI57140.2023.10134091&partnerID=40&md5=5ccd021a2a4ceba6969c48d0512a40c4},
	affiliations = {SRM Institute of Science and Technology, Department of Electronics and Communication Engineering, Kattankulathur, TN, India; SRM Institute of Science and Technology, Kattankulathur, TN, India},
	abstract = {Many children with autism most frequently exhibit stereotypical movements (SM) such as arm flapping, spinning, body rocking, etc., which are controllable at early stages with proper detection and treatment procedure. Though, the detection of the SM relies on careful observations and time consuming manual quantification, an intelligent assistive diagnostic tool to capture the SM could aid the therapist for better provision of treatment. This study presents a stereotypic movement detection and analyzing (SMDA) software that apprehended SM of selected body part or whole body in terms of intensity and frequency. The SMDA is powered by (i) computer vision (CV), a video pre-processing module; and (ii) media pipe library (MPL) with a machine learning (ML) framework, to process recorded videos and provide vital information to therapist. Using CV and MPL, landmarks of body parts (LBP) are identified and subsequently labeled them. Further, the labelled landmarks (example: wrist) are tracked during the onset of SM in recorded videos and extracted the X- Y coordinates. Using, data peak filtering algorithm (DPFA), the intensity of SM and its frequency are estimated. Quick detection of vital parameters of SM and versatile LBP selection, features SMDA standout to be a better diagnostic assistive tool to the therapist. © 2023 IEEE.},
	author_keywords = {autism; Computer vision; Media pipe; stereotypic behavior},
