	doi = {10.1109/PRMVIA63497.2024.00021},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85205312652&doi=10.1109%2FPRMVIA63497.2024.00021&partnerID=40&md5=0395e07707a51a26b1ebdcc0a6afb279},
	affiliations = {Nanjing University of Aeronautics and Astronautics, College of Computer Science and Technology, Nanjing, Jiangsu, China},
	abstract = {The multi-site analysis provides the potential for improving diagnostic accuracy by integrating data from various sites. However, despite its above promise, multi-site applications face challenges such as data leakage and the non-independence and non-identical distribution of data. In this paper, we propose a method for multi-site joint brain disease diagnosis using brain network topological prototypes. Leveraging the federated learning (FL) framework, our approach enables collaborative analysis of functional magnetic resonance imaging (fMRI) data across multiple sites without sharing raw data, thus ensuring data privacy. By fusing brain networks constructed from multi-site topology prototypes with local Pearson coefficients, we develop a contrastive learning-based model for brain disease diagnosis capable of identifying brain diseases and extracting topological structure prototypes. Experimental results demonstrate that our method outperforms existing federated learning algorithms on multi-site datasets related to Autism Spectrum Disorder (ASD) and Attention Deficit Hyperactivity Disorder (ADHD). © 2024 IEEE.},
