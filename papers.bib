	affiliations = {Hamm-Lippstadt University of Applied Sciences, Hamm, Germany; The Royal Institute of Technology (KTH), Stockholm, Stockholms, Sweden; IRCCS Eugenio Medea, Bosisio Parini, LC, Italy; Università degli Studi di Milano-Bicocca, Milan, MI, Italy},
