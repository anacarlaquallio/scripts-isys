	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105012120775&doi=10.1109%2FOTCON65728.2025.11070816&partnerID=40&md5=a9d67697a003f673c441fe146e50d2f4},
	affiliations = {Sahyadri College of Engineering & Management, Department of Information Science and Engineering, Mangalore, KA, India},
	abstract = {The analysis and detection of Autism Spectrum Disorder (ASD) using machine learning is a rapidly advancing area of research, aiming to improve diagnostic accuracy and efficiency. In this paper, we present a hybrid model that combines MobileNet for image classification and Artificial Neural Networks (ANN) for analyzing CSV datasets. By integrating both deep learning and traditional machine learning techniques, the model enhances ASD detection across various age groups. We begin by preprocessing both image and tabular data to ensure high-quality input for the models. MobileNet, known for its efficiency in processing image data, is used to extract key features from facial images linked to ASD. At the same time, an ANN analyzes structured data such as behavioral assessments and clinical features from the CSV dataset. By fusing these two approaches, the model enables a more comprehensive analysis, capturing both visual and behavioral indicators of autism. The hybrid model is evaluated using several performance metrics, showing significant improvements in accuracy over standalone models. These results not only demonstrate enhanced detection rates but also highlight reduced computational complexity, making the model well-suited for real-world clinical applications. This research contributes to the ongoing efforts to leverage advanced machine learning techniques for early ASD diagnosis and intervention, ultimately aiming to improve outcomes for individuals and their families. © 2025 IEEE.},
