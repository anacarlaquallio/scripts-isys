@CONFERENCE{Liao2025243,
	author = {Liao, Chengzhe and Liu, Wei},
	title = {YOLOv11-ASD: Improved YOLOv11 for Multi-Scale and Small Object Detection},
	year = {2025},
	pages = {243 - 247},
	doi = {10.1109/ICCEA65460.2025.11103348},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105014908989&doi=10.1109%2FICCEA65460.2025.11103348&partnerID=40&md5=4d6fe8f86c1965074d6a44357fbb6916},
	affiliations = {Wuhan University, School of Physics and Technology, Wuhan, Hubei, China; Wuhan University, School of Microelectronics, Wuhan, Hubei, China; Wuhan Textile University, School of Mathematical and Physical Sciences, Wuhan, Hubei, China; Wuhan Institute of Quantum Technology, Wuhan, China},
	abstract = {Object detection plays a vital role in autonomous driving, where achieving both high precision and computational efficiency is a major challenge. To address the limitations of YOLOv11 in feature representation and computational cost, we propose YOLOv11-ASD, an enhanced architecture integrating three lightweight modules: ADown, SPPF-SENetV2, and DySample. ADown optimizes downsampling by reducing redundant convolutional operations; SPPF-SENetV2 enhances global receptive fields and channel-wise attention; DySample introduces a dynamic point-based upsampling mechanism at lower computational cost. Experiments on the KITTI dataset show that, compared to the original YOLOv11, YOLOv11-ASD improves mAP@0.5 by 2.4% (reaching 93.5%), reduces parameter size 19%, and lowers GFLOPs by 19.2%. The results demonstrate that the proposed model achieves higher detection accuracy and faster inference, making it highly effective for realtime object detection applications. © 2025 IEEE.},
	author_keywords = {autonomous driving; object detection; yolov11; yolov11-asd},
	keywords = {Autonomous vehicles; Computational cost; Computational efficiency; Memory architecture; Object recognition; Autonomous driving; Computational costs; Down sampling; Feature representation; High-precision; Multi-scales; Objects detection; Small object detection; Yolov11; Yolov11-asd; Object detection},
