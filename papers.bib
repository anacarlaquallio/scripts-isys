	affiliations = {Universidad Nacional de La Plata, Faculty of Computer Science, La Plata, Provincia de Buenos Aires, Argentina; International Ibero-American University, Campeche, Mexico; Universidad Internacional del Ecuador, Quito, Pichincha, Ecuador},
