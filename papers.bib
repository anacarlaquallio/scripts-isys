@CONFERENCE{Shi2023290,
	author = {Shi, Xiufang and Zhao, Chunhai and Li, Wenjuan and Zheng, Yongjun and Chi, Yuhao and Shi, Huilan},
	title = {A Hybrid Tool by Spherical Video-based Virtual Reality for Teacher Coaching Training of Early Childhood Autism Rehabilitation},
	year = {2023},
	pages = {290 - 293},
	doi = {10.1109/ECICE59523.2023.10382980},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85183925931&doi=10.1109%2FECICE59523.2023.10382980&partnerID=40&md5=60b2afd923b2d61e20087c2b0486a88b},
	affiliations = {NO 984 Hospital of PLA, Beijing, Beijing, China; Pengzhou People's Hospital, Pengzhou, Sichuan, China},
	abstract = {Early childhood autism is a pervasive developmental disorder that encompasses three basic features: isolation of interpersonal relationships, difficulties in verbal communication, and behavioral disorders. Autism is an increasingly common neurodevelopmental disorder, and the focus of autism treatment is early diagnosis and intervention. Long-term treatment helps children recover. Successful cases of technology-assisted training in rehabilitation are gradually increasing, and Spherical Video-based Virtual Reality (SVVR) in psychology-assisted early childhood autism rehabilitation is used with a variety of fusion applications for better rehabilitation effects. We conducted a mixed-methods study of SVVR-based identification and assisted rehabilitation training for early childhood autism to improve its treatment and rehabilitation. In this study, data were collected using questionnaires and semi-structured interviews to understand issues related to the effectiveness of SVVR versus traditional rehabilitation methods. The results of the experiment showed that there was a significant improvement in the learners' intercultural communication skills based on the SVVR blended learning approach. The results of the interviews indicated the effective use of SVVR in rehabilitation and affirmed the advantages of this hybrid approach. The method can be used for other patients with other psychological diseases. The experiments on SVVR in psychology-assisted early childhood autism proved the superiority and validity of the proposed method. © 2023 IEEE.},
