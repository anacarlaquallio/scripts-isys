@ARTICLE{Yu2026,
	author = {Yu, Renping and Zhu, Jixiang and Peng, Chao and Zhao, Zhe and Chen, Mingming and Zhang, Rui},
	title = {Adversarial training based adaptive weighted hybrid network for autism spectrum disorder diagnosis},
	year = {2026},
	journal = {Biomedical Signal Processing and Control},
	volume = {114},
	pages = {},
	doi = {10.1016/j.bspc.2025.109313},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105023316404&doi=10.1016%2Fj.bspc.2025.109313&partnerID=40&md5=71d1652a2ec0b780f0e94b93305b49f7},
	affiliations = {Zhengzhou University, Henan Key Laboratory of Brain Science and Brain-Computer Interface Technology, Zhengzhou, Henan, China},
	abstract = {Autism spectrum disorder (ASD) is a severe developmental disorder characterized by highly variable symptoms and severity, posing significant challenges for clinical diagnosis. Functional magnetic resonance imaging has served as a crucial tool in identifying brain disorders, providing important insights into the discrimination and analysis of ASD. Graph convolutional networks can effectively spread and aggregate information through the adjacency relationship between nodes on the topology of network, and has advantages in discovering brain connectivity patterns associated with neuropsychiatric disorders. However, existing graph neural networks often fail to effectively capture the discriminative representations that can reliably differentiate ASD patients from healthy controls. In this work, we propose an adversarial training-based adaptive weighted hybrid network for ASD identification, employing joint training through contrastive loss and cross-entropy loss to help the model acquire discriminative representations. Specifically, we integrate contrastive learning within an adversarial training framework, guiding graph convolutional networks to extract high-quality disease-relevant features. Simultaneously, cross-entropy loss is applied to synchronize representation learning and downstream classification, ensuring robust optimization. Furthermore, we introduce a dynamic weighting strategy that adaptively balances the contributions of representation learning and classifier learning across different training stages, thereby improving model convergence and performance. Extensive experiments on the Autism Brain Imaging Data Exchange (ABIDE) dataset, involving 426 subjects from three different sites, demonstrate consistent improvements over competitive methods. Moreover, the salient brain regions and abnormal functional connections identified by our model show great potential for uncovering novel biomarkers in ASD research, making it a promising approach for clinical applications. © 2025 Elsevier Ltd},
	author_keywords = {Autism spectrum disorder; Functional MRI; Graph contrastive learning; Graph convolutional networks; Hybrid network},
	keywords = {Brain; Brain mapping; Classification (of information); Computer aided diagnosis; Contrastive Learning; Convolution; Diseases; Entropy; Graph neural networks; Learning systems; Magnetic resonance imaging; Autism spectrum disorders; Convolutional networks; Cross entropy; Developmental disorders; Entropy loss; Functional MRI; Functionals; Graph contrastive learning; Graph convolutional network; Hybrid network; Clinical research; adolescent; adult; adversarial learning; angular gyrus; Article; autism; BOLD signal; brain region; cerebrospinal fluid; classifier; controlled study; convolutional recurrent neural network; disease severity; empathy; entropy; feature extraction; feature learning (machine learning); female; functional connectivity; functional magnetic resonance imaging; graph convolutional network; graph neural network; head movement; human; image processing; inferior frontal gyrus; inferior parietal lobule; insula; k nearest neighbor; lingual gyrus; long short term memory network; major clinical study; male; middle frontal gyrus; motor control; multilayer perceptron; nerve cell network; neuroimaging; primary motor cortex; social cognition; superior frontal gyrus; support vector machine; supramarginal gyrus; white matter},
	correspondence_address = {R. Zhang; Henan Key Laboratory of Brain Science and Brain-ComputerInterface Technology, School of Electrical and Information Engineering, Zhengzhou University, Zhengzhou, 450001, China; email: ruizhang@zzu.edu.cn},
	publisher = {Elsevier Ltd},
