@ARTICLE{Chen2025,
	author = {Chen, Lian and Zhang, Jinning and Wang, Yixu and Wang, Daiyue and Xiao, Jian and Dai, Shuangliang and Liu, Wangtao and Ling, Song and Dong, Liang},
	title = {Additive-state-decomposition complementary zero dynamic inversion tracking control of non-affine pure-feedback systems},
	year = {2025},
	journal = {Journal of Control and Decision},
	pages = {},
	doi = {10.1080/23307706.2025.2567521},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105021512350&doi=10.1080%2F23307706.2025.2567521&partnerID=40&md5=b326abbcc18df2b600192d04888a3da2},
	affiliations = {Ministry of Transport of the People's Republic of China, Beijing, Beijing, China; Ltd., Beijing, Beijing, China; Ltd., Beijing, Beijing, China; Beijing Jiaotong University, Beijing, China; FAW Group Corporation, Changchun, Jilin, China},
	abstract = {This study addresses trajectory tracking control challenges in pure-feedback nonlinear systems with inherent non-affine control characteristics. Existing approaches typically address non-affine pure-feedback issues through differential mean-value theorem applications. However, this paper proposes a new method to solve the non-affine pure feedback problem, that is, using additive-state-decomposition (ASD) complementary zero technology. The new method is less conservative than the differential mean value theorem, for example, the constraints on the partial derivatives of non-affine functions are released. Next, extended state observers are introduced to estimate unknown functions. A novel composite control architecture is developed through systematic integration of command-filtered backstepping methodology and dynamic inversion principles, specifically designed for complex pure-feedback non-affine dynamic systems. Rigorous stability analysis demonstrates that all closed-loop signals maintain semi-global uniform ultimate boundedness properties under the proposed control scheme. Comparative numerical evaluations involving high-order nonlinear mechatronic system models are conducted to validate theoretical findings and examine control performance enhancements. © 2025 Northeastern University, China.},
