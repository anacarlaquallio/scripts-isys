@ARTICLE{de Gois Marques2023292,
	author = {de Gois Marques, Denis and Dallegrave, Tâmara D. and Rodrigues, Cleyton Mario De Oliveira and Santos, Wylliams Barbosa},
	title = {Successful Practices in Industry-Academy Collaboration in the Context of Software Agility: A Systematic Literature Review},
