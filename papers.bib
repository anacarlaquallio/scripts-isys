@ARTICLE{Albahri2023225,
	author = {Albahri, A. S. and Zaidan, A. A. and AlSattar, Hassan A. and A Hamid, Rula and Albahri, O. S. and Qahtan, Sarah and Alamoodi, Abdullah Hussein},
	title = {Towards physician's experience: Development of machine learning model for the diagnosis of autism spectrum disorders based on complex T-spherical fuzzy-weighted zero-inconsistency method},
