	doi = {10.1109/ICEET65156.2024.10913621},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105001422213&doi=10.1109%2FICEET65156.2024.10913621&partnerID=40&md5=e77dcf9721b79027c40d5626c0be07fe},
	affiliations = {Pamantasan ng Lungsod ng Maynila, Manila, Philippines},
	abstract = {Children with Autism Spectrum Disorder (ASD) often experience unpredictable meltdowns due to complex behavioral and environmental factors. A lack of accessible information on prevention and management strategies, along with a shortage of specialized healthcare professionals, complicates support for families. This study develops a mobile application that predicts meltdowns, featuring a recommendation engine for prevention strategies and a location-based service for nearby healthcare providers. The app utilizes the CNN-LSTM model (MoViNets) to classify tantrums and generate tailored strategies. The MoViNets model achieved training and validation accuracies of 82.03 % and 87.30%, respectively, with an overall classification accuracy of 90%. Evaluations from therapy centers indicated strong functionality (mean of 4.33), usability (4.19), reliability (4.14), and security (4.40), resulting in an overall mean rating of 4.27, signifying a well-rounded system in terms of functionality and user experience. © 2024 IEEE.},
