	year = {2024},
	pages = {795 - 801},
	doi = {10.1109/CBASE64041.2024.10824670},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85217154495&doi=10.1109%2FCBASE64041.2024.10824670&partnerID=40&md5=74753c8759ef30b53ab4b14d2c79bbb1},
	affiliations = {GAC Automotive Engineering Institute, Guangzhou, China; Wuhan University of Technology, Wuhan, Hubei, China; Fuzhou University, College of Mechanical Engineering and Automation, Fuzhou, Fujian, China},
	abstract = {In recent years, the rise of electric vehicles (EVs) has brought Active Sound Design (ASD) to the forefront as a crucial methodology for enhancing both acoustic quality and the overall driving experience. To address the challenges associated with sound quality design in electric vehicles, an offline simulation software for Active Sound Design (ASD) systems has been developed using the MATLAB platform in this paper, where the vehicle dynamics model and three distinct sound synthesis algorithms have been incorporated into the software, and the formulation and modification of ASD system control strategies can be implemented. The simulations of vehicle operating conditions can be performed, the acoustic performance of the ASD system can be evaluated, and control strategies can be modified expeditiously based on the software developed in this paper. Moreover, the software supports integration with a Digital Signal Processing (DSP) hardware platform, facilitating a seamless closed-loop from sound design to real vehicle application, which contribute to substantially enhance the efficiency of ASD system development. The practical application effect of the software developed are further demonstrated on the electric SUV model, and the results show that the sound of the real vehicle test is the same as that of the software design, which proves its effectiveness and practicability in the active sound design of the vehicle. © 2024 IEEE.},
	author_keywords = {component; Offline simulation software; Real vehicle application; Sound active design; Sound quality; Sound synthesis algorithm},
	keywords = {Computer software selection and evaluation; Direct digital control systems; Magnetic levitation vehicles; Component; Off-line simulations; Offline simulation software; Real vehicle application; Real vehicles; Simulation software; Sound active design; Sound Quality; Sound synthesis algorithm; Sound-synthesis; Synthesis algorithms; Vehicle applications; MATLAB},
