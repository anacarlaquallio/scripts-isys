	title = {Classification of Eye-Tracking Data Based on Spatiotemporal Attention Encoding},
	year = {2025},
	journal = {Proceedings - ICASSP, IEEE International Conference on Acoustics, Speech and Signal Processing},
	pages = {},
	doi = {10.1109/ICASSP49660.2025.10889246},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009589053&doi=10.1109%2FICASSP49660.2025.10889246&partnerID=40&md5=a76d3dc271ab178ba8fef4c1306157cd},
	affiliations = {Beijing University of Chemical Technology, Beijing, China; Northwestern Polytechnical University, Xi'an, Shaanxi, China; the Affiliated Hospital of Northwest University, Shaanxi, China; Xi'an Jiaotong University, Xi'an, Shaanxi, China},
	abstract = {Eye movement classification can decode cognitive processes, offering valuable insights for a wide range of applications. However, existing eye movement classification models primarily focus on static fixation-based features and often neglect the encoding of spatiotemporal eye movement features, which are crucial for accurately reconstructing visual attention. To address this limitation, we propose a spatiotemporal attention encoding (STAE) model that jointly captures both spatial and temporal features for eye-tracking classification. First, we utilize a Vision Transformer (ViT) to extract spatial features from fixations by taking global competition into consideration. We then introduce a global weighting Gated Recurrent Unit (GRU) model to capture temporal correlations from the feature sequence. Specifically, we propose a hidden-state-based weighting to fuse the influence of different fixations on the current fixation. In the experiment, we evaluated our model on three tasks: autism spectrum disorder (ASD) identification, visual task classification, and age classification. Experiential results across three databases demonstrate that our model outperforms existing methods and shows strong adaptability across various eye movement classification tasks. The code is available at https://github.com/HectorTo/spatiotemporalattention- encoding-STAE-. © 2025 Institute of Electrical and Electronics Engineers Inc.. All rights reserved.},
	author_keywords = {autism spectrum disorder (ASD); eye-tracking classification; spatiotemporal features; visual attention},
	keywords = {Behavioral research; Classification (of information); Cognitive systems; Diseases; Eye movements; Eye tracking; Image coding; Signal encoding; Autism spectrum disorder; Autism spectrum disorders; Encodings; Eye movement classifications; Eye-tracking; Eye-tracking classification; Spatial features; Spatiotemporal feature; Tracking data; Visual Attention; Encoding (symbols)},
	correspondence_address = {C. Xia; Northwestern Polytechnical University, China; email: cxia@nwpu.edu.cn},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
