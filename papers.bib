@CONFERENCE{Perkusich2025,
	author = {Perkusich, Mirko Barbosa and Silva, Izabella and Albuquerque, Danyllo Wagner and Gorgônio, Kyller Costa and Perkusich, Angelo},
	title = {Evaluating the Quality of User Stories: A Comparative Study of Large Language Models and Rule-Based Tool},
	year = {2025},
	pages = {},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105021954320&partnerID=40&md5=049b3e19ee2a686d3e13740bfced8c3b},
	affiliations = {Universidade Federal de Campina Grande, Campina Grande, PB, Brazil},
	abstract = {Evaluating the quality of User Stories is critical to the success of agile software development (ASD). Rule-based tools like AQUSA, based on the Quality User Story (QUS) framework, offer reliable checks for structural conformity but often miss context-sensitive or stylistic issues. This study explores the potential of Large Language Models (LLMs) to enhance or complement such tools in identifying quality defects in User Stories. We compare AQUSA with the DeepSeek LLM using a benchmark dataset of 15 User Stories from the original QUS validation study, with all outputs cross-validated by two expert reviewers. Our evaluation combines quantitative metrics-precision, recall, and F1-score-with qualitative analysis of feedback expressiveness and defect relevance. Results show that DeepSeek achieved higher recall (0.87) and matched AQUSA's F1-score (0.84), while AQUSA maintained slightly higher precision (0.87 vs.0.81). However, both tools missed some expert-identified defects, particularly those requiring contextual or domain-specific interpretation. These findings highlight the limitations of using either tool in isolation and support a dual-tool strategy: applying AQUSA for structural issues and DeepSeek for linguistic and pragmatic aspects, with both outputs reviewed by experts. This layered approach can improve not only the technical quality of User Stories, but also stakeholder alignment, backlog clarity, and planning accuracy. © 2025 University of Split, FESB.},
	author_keywords = {Agile Requirements Engineering; AQUSA Tool; Large Language Models; Quality Assessment; QUS Framework; User Stories},
	keywords = {Agile manufacturing systems; Computational linguistics; Defects; Software quality; Agile requirement engineering; Agile requirements; AQUSA tool; Language model; Large language model; Quality assessment; Quality user story framework; Requirement engineering; User stories; Requirements engineering},
