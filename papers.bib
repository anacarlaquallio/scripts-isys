	year = {2024},
	pages = {1 - 10},
	doi = {10.1109/CONISOFT63288.2024.00012},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85216791901&doi=10.1109%2FCONISOFT63288.2024.00012&partnerID=40&md5=7488cf0f35551b9ffc548ccaa942904b},
	affiliations = {Universidad Veracruzana, Facultad de Estadística e Informática, Xalapa, VER, Mexico},
	abstract = {Given their nature, mobile applications require a high degree of usability, thus necessitating development processes which procure this quality attribute. Among such processes are those which integrate agile software development (ASD) with user-centered design (UCD), whose efficiency in creating more usable software has been proven in non-mobile software development projects. This study presents a systematic literature review with the aim of identifying the state of the art of agile-UCD Integration applied to mobile application development. A total of 32 studies were included, leading to the synthesis of frameworks used to integrate ASD with UCD, the UCD techniques involved in the process, the software tools used to design apps under agile-UCD, the challenges in adopting this approach as well as recommendations for their mitigation, and the benefits that both developers and users of mobile apps obtain when their software is developed with this approach. © 2024 IEEE.},
