	year = {2024},
	journal = {Proceedings of the Annual Conference of the International Speech Communication Association, INTERSPEECH},
	pages = {1430 - 1434},
	doi = {10.21437/Interspeech.2024-131},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85214832570&doi=10.21437%2FInterspeech.2024-131&partnerID=40&md5=b804c2caf6ad5f846a0d46b71fc41a80},
	affiliations = {Seoul National University, Department of Linguistics, Seoul, South Korea; Seoul National University, Department of French Language Education, Seoul, South Korea},
	abstract = {Autism Spectrum Disorder (ASD) is a lifelong condition that significantly influencing an individual's communication abilities and their social interactions. Early diagnosis and intervention are critical due to the profound impact of ASD's characteristic behaviors on foundational developmental stages. However, limitations of standardized diagnostic tools necessitate the development of objective and precise diagnostic methodologies. This paper proposes an end-to-end framework for automatically predicting the social communication severity of children with ASD from raw speech data. This framework incorporates an automatic speech recognition model, fine-tuned with speech data from children with ASD, followed by the application of fine-tuned pre-trained language models to generate a final prediction score. Achieving a Pearson Correlation Coefficient of 0.6566 with human-rated scores, the proposed method showcases its potential as an accessible and objective tool for the assessment of ASD. © 2024 International Speech Communication Association. All rights reserved.},
