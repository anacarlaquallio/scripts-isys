	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85204891079&doi=10.32604%2Fcmes.2023.029631&partnerID=40&md5=164a65f57486bc2d1e20e73afc7ad85d},
	affiliations = {Hainan Medical University, College of Biomedical Information and Engineering, Haikou, Hainan, China; Haikou University of Economics, TJ-YZ School of Network Science, Haikou, Hainan, China; Tsinghua University, Department of Earth System Science, Beijing, China},
	abstract = {Watermarks can provide reliable and secure copyright protection for optical coherence tomography (OCT) fundus images. The effective image segmentation is helpful for promoting OCT image watermarking. However, OCT images have a large amount of low-quality data, which seriously affects the performance of segmentation methods. Therefore, this paper proposes an effective segmentation method for OCT fundus image watermarking using a rough convolutional neural network (RCNN). First, the rough-set-based feature discretization module is designed to preprocess the input data. Second, a dual attention mechanism for feature channels and spatial regions in the CNN is added to enable the model to adaptively select important information for fusion. Finally, the refinement module for enhancing the extraction power of multi-scale information is added to improve the edge accuracy in segmentation. RCNN is compared with CE-Net and MultiResUNet on 83 gold standard 3D retinal OCT data samples. The average dice similarly coefficient (DSC) obtained by RCNN is 6% higher than that of CE-Net. The average 95 percent Hausdorff distance (95HD) and average symmetric surface distance (ASD) obtained by RCNN are 32.4% and 33.3% lower than those of MultiResUNet, respectively. We also evaluate the effect of feature discretization, as well as analyze the initial learning rate of RCNN and conduct ablation experiments with the four different models. The experimental results indicate that our method can improve the segmentation accuracy of OCT fundus images, providing strong support for its application in medical image watermarking. © 2024 Tech Science Press. All rights reserved.},
	author_keywords = {attention mechanism; feature discretization; image segmentation; rough convolutional neural network; Watermarks},
	keywords = {Image enhancement; Image segmentation; Optical coherence tomography; Optical data processing; Optical tomography; Watermarking; Attention mechanisms; Coherence tomography; Convolutional neural network; Feature discretization; Fundus image; Images segmentations; Optical-; Rough convolutional neural network; Segmentation methods; Watermark; Convolutional neural networks},
