	affiliations = {Politecnico di Milano, Department of Mechanical Engineering, Milan, MI, Italy; Università Telematica Pegaso, Naples, Italy; Politecnico di Torino, Department of Electronics and Telecommunications, Turin, TO, Italy; Politecnico di Milano, Department of Design, Milan, MI, Italy; Consiglio Nazionale delle Ricerche, Rome, RM, Italy},
