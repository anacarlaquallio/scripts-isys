	title = {AI Integrated Support System for Detecting Autism Spectrum Disorder in Children},
	year = {2024},
	pages = {1458 - 1463},
	doi = {10.1109/ICICNIS64247.2024.10823202},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85217176315&doi=10.1109%2FICICNIS64247.2024.10823202&partnerID=40&md5=5cc14cb3d5199e12c539b71c7da889c6},
	affiliations = {SCEM, Department of Electrical & Computer Engineering, Mangalore, KA, India},
	abstract = {Autism Spectrum Disorder (ASD) is a developmental disorder that is often linked to expensive medical care and drawn-out evaluations. These difficulties can be lessened with early identification of ASD characteristics. Conventional approaches to diagnosing ASD frequently entail laborious, subjective, and ineffective processes based on expert knowledge. The adoption of clever AI-based algorithms that can identify patterns from past ASD cases and healthy people is a more promising method of expediting the diagnostic procedure. Compared to current techniques, this strategy seeks to be more accurate and efficient. The suggested system consists of an intelligent web service that employs a Convolutional Neural Network (CNN) and a mobile application that gathers data via questionnaires. By continuously learning from the data, the CNN-based system gradually increases its accuracy. In comparison to other traditional methods, this approach performed better when tested, especially when it came to identifying cases that were not ASD. With improved sensitivity, specificity, and accuracy, it proved to be a useful tool for medical practitioners. By improving the effectiveness and efficiency of the diagnosis process, this approach has the potential to completely transform the way ASD is diagnosed in the future. © 2024 IEEE.},
	author_keywords = {accelerometer; ASD; disorder; gloves; sensors},
	keywords = {Diagnosis; Diseases; Autism spectrum disorders; Conventional approach; Convolutional neural network; Developmental disorders; Disorder; Expert knowledge; Glove; Integrated supports; Process-based; Support systems; Convolutional neural networks},
