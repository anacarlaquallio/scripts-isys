@CONFERENCE{Samonte2024400,
	author = {Samonte, Mary Jane C. and Nitta, Kennichi O. and Datu, Caitlin D. and Erpelo, Rosanne},
	title = {Critical Analysis on the Design and Development of an E-Learning System for Autism Spectrum Disorder Intervention through Gamified Augmented Reality and Emotion-Recognition},
	year = {2024},
	pages = {400 - 409},
	doi = {10.1145/3695652.3695658},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85209085602&doi=10.1145%2F3695652.3695658&partnerID=40&md5=6914bdf2a39c3a06724249771be38ba3},
	affiliations = {Mapúa University, School of Information Technology, Manila, Philippines},
	abstract = {In the Philippines the state of care for those with Autism Spectrum Disorder (ASD) is affected by factors such as upfront cost, the availability of care staff and care resources, and the limited integration of technology. Individuals with ASD often have trouble reliably identifying emotions in social situations, a known trait that has inspired much research into relevant assistive technologies. Many technologies have been proposed to aid in improving the condition of those with ASD via various means. This paper discusses a system which aims to use computer vision integrated with Augmented Reality (AR) to develop a novel assistive application. This application's purpose is to aid care professionals working with individuals with ASD through a system that can recognize facial expressions, output a reading on said emotion, and then display that output in a real-time AR display. © 2024 ACM.},
