	volume = {112},
	pages = {},
	doi = {10.1016/j.bspc.2025.108705},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105016457872&doi=10.1016%2Fj.bspc.2025.108705&partnerID=40&md5=cc31452bb2f8aecaab9d780da28dcfde},
	affiliations = {Hangzhou Dianzi University, School of Computer Science and Technology, Hangzhou, Zhejiang, China; Hangzhou Dianzi University, Institute of Intelligent Biomedicine, Hangzhou, Zhejiang, China},
	abstract = {Large-scale vision and language models are increasingly applied across various domains, including medical imaging processing and report generation. However, the significant memory and computational demands of these large models often present a challenge for their application in medical environments. This study aims to develop an efficient method by leveraging a pretrained large model and cross modal feature fusion for downstream medical tasks, with the goal of enhancing the network's performance in tumor segmentation and medical report generation jointly. We propose a low-rank adaptation-based multitask learning (LRMTL) network, which is specifically designed for breast tumor segmentation and report generation. The low-rank adaptation method efficiently leverages pretrained large models, enabling effective multitask learning with reduced computational overhead. Additionally, we introduce a paired cross-modal attention (PCMA) module, which employs multihead attention mechanisms to integrate cross-modal features, thereby improving tumor segmentation accuracy and report quality. Our LRMTL network achieves robust performance, with tumor segmentation metrics of 0.639 (average surface distance, ASD), 9.316 (95% Hausdorff distance, HD95), 0.757 (Dice coefficient), and 0.619 (intersection over union, IoU). For medical report generation, the model attains bilingual evaluation understudy (BLEU) scores of 0.563 (BLEU-1), 0.395 (BLEU-2), 0.297 (BLEU-3), 0.222 (BLEU-4), and a recall-oriented understudy for gisting evaluation (ROUGE) score of 0.365. Notably, the trainable parameters in our method account for less than 10% of the network's total parameters, demonstrating high efficiency. The LRMTL network represents a significant advancement in applying large-scale models to medical tasks, offering an efficient and effective solution for joint tumor segmentation and report generation. © 2025 Elsevier Ltd},
	author_keywords = {Low-Rank adaptation; Multitask learning; Report generation; Tumor segmentation},
	keywords = {Computational efficiency; Image segmentation; Learning algorithms; Learning systems; Medical image processing; Multi-task learning; Bilinguals; Breast tumour; Cross-modal; Large models; Large-scales; Learning network; Low-rank adaptation; Multitask learning; Report generation; Tumor segmentation; Tumors; adult; aged; Article; breast tumor; crossmodal attention; deep learning; human; image quality; image segmentation; language model; task performance},
	correspondence_address = {M. Fan; Institute of Intelligent Biomedicine, Hangzhou Dianzi University, Hangzhou, 310018, China; email: ming.fan@hdu.edu.cn},
	publisher = {Elsevier Ltd},
	issn = {17468094},
