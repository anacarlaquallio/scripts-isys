@ARTICLE{Prakash202347907,
	author = {Prakash, Varun Ganjigunte and Kohli, Manu and Kohli, Swati and Prathosh, Aragulla Prasad and Wadhera, Tanu and Das, Diptanshu and Panigrahi, Debasis and Kommu, John Vijay Sagar},
	title = {Computer Vision-Based Assessment of Autistic Children: Analyzing Interactions, Emotions, Human Pose, and Life Skills},
	year = {2023},
	journal = {IEEE Access},
	volume = {11},
	pages = {47907 - 47929},
	doi = {10.1109/ACCESS.2023.3269027},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85153795570&doi=10.1109%2FACCESS.2023.3269027&partnerID=40&md5=5069de3bfb1839c036d5c18af79a8d2d},
	affiliations = {CogniAble, Gurugram, India; Indian Institute of Science, Signal Processing Building West, Bengaluru, KA, India; Indian Institute of Information Technology Una, Department of Electronics and Communication Engineering, Una, HP, India; Institute of Neurodevelopment, Kolkata, India; Jagannath Hospital, Bhubaneswar, OR, India; National Institute of Mental Health and Neuro Sciences, Department of Child and Adolescent Psychiatry, Bengaluru, KA, India},
	abstract = {In this paper, the proposed work implements and tests the computer vision applications to perform the skill and emotion assessment of children with Autism Spectrum Disorder (ASD) by extracting various bio-behaviors, human activities, child-therapist interactions, and joint pose estimations from the recorded videos of interactive single- or two-person play-based intervention sessions. A comprehensive data set of 300 videos is amassed from ASD children engaged in social interaction, and three novel deep learning-based vision models are developed, which are explained as follows: (i) activity comprehension to analyze child-play partner interactions (activity comprehension model); (ii) an automatic joint attention recognition framework using head and hand pose; and (iii) emotion and facial expression recognition. The proposed models are also tested on children's real-world, 68 unseen videos captured from the clinic, and public datasets. The activity comprehension model has an overall accuracy of 72.32%, the joint attention recognition models have an accuracy of 97% for follow eye gaze and 93.4% for hand pointing, and the facial expression recognition model has an overall accuracy of 95.1%. The proposed models could extract behaviors of interest, events of activities, emotions, and social skills from free-play and intervention session videos of long duration and provide temporal plots for session monitoring and assessment, thus empowering clinicians with insightful data useful in diagnosis, assessment, treatment formulation, and monitoring ASD children with limited supervision. © 2013 IEEE.},
	author_keywords = {activity comprehension; applied behavior analysis; ASD screening; Autism spectrum disorder; facial expressions; joint attention},
	keywords = {Behavioral research; Computer vision; Deep learning; Digital storage; Diseases; Emotion Recognition; Human computer interaction; Variable speed drives; Activity comprehension; Applied behavior analyse; Autism; Autism spectrum disorder screening; Autism spectrum disorders; Behavior analysis; Behavioral science; Computational modelling; Facial Expressions; Joint attention; Variable-speed drives; Video; Face recognition},
