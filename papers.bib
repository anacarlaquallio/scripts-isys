@ARTICLE{Pandey2025311,
	author = {Pandey, Suruchi and Chandwadkar, Rajesh and Gaikwad, Hemlata Vivek},
	title = {Being Inclusive with Neurodiverse Workforce—Applications of ICT in Training},
	year = {2025},
	journal = {Lecture Notes in Networks and Systems},
	volume = {1383 LNNS},
