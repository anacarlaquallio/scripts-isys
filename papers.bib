@ARTICLE{Marco2024,
	author = {Marco, Nicholas and Şentürk, Damla and Jeste, Shafali Spurling and DiStefano, Charlotte C. and Dickinson, Abigail H. and Telesca, Donatello},
	title = {Flexible regularized estimation in high-dimensional mixed membership models},
	year = {2024},
