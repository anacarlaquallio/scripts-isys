	title = {Grab-and-Release Spelling in XR: A Feasibility Study for Nonspeaking Autistic People Using Video-Passthrough Devices},
	year = {2025},
	pages = {81 - 102},
	doi = {10.1145/3715336.3735719},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105020668964&doi=10.1145%2F3715336.3735719&partnerID=40&md5=aa5a5f98b4aaf49b97e9f0801c83618f},
	affiliations = {University of Calgary, Department of Electrical and Software Engineering, Calgary, AB, Canada; Alberta Children’s Hospital Research Institute, Calgary, AB, Canada; University of Calgary, Department of Electrical and Software Engineering, Calgary, AB, Canada; Cumming School of Medicine, Calgary, AB, Canada; University of Virginia, Charlottesville, VA, United States; University of Calgary, Calgary, AB, Canada},
	abstract = {This paper investigates the feasibility of using video-passthrough Extended Reality (XR) devices to support communication in nonspeaking autistic individuals. Prior XR research with this population has relied on expensive augmented reality headsets and limited interactions to near-hand tapping. We present LetterBox, a novel application developed for video-passthrough XR headsets such as the Meta Quest series, which enables spelling through a "grab-snap-release"interaction. The app supports three immersion levels and includes a dynamic pass-through window tracking caregiver presence. We conducted a study with 19 participants across four sites in North America. All participants completed a multiphase spelling task and answered open-ended questions using LetterBox. Despite concerns about tolerability, all participants wore the headset throughout the session, with only one requesting a break. Participants achieved a mean spelling accuracy of. In the open-spelling task, 14 participants provided answers, often independently and with minimal support. Reaction time and interaction speed data highlight the influence of visual complexity, offering insights for designing interfaces that reduce errors and improve speed. Our findings show that video-passthrough XR can be tolerated by nonspeakers and that the grab-snap-release method offers a promising alternative to tapping, particularly for those with significant motor control challenges. By leveraging affordable hardware, a novel interaction method, and progressive immersion, this study reveals important findings and opens new pathways to inclusive assistive technologies for this under-served population. © 2025 Copyright held by the owner/author(s). Publication rights licensed to ACM.},
	author_keywords = {Assistive technology; Extended reality; Nonspeaking autism; User study},
	keywords = {Assistive technology; Human computer interaction; Human engineering; Interactive computer graphics; Extended reality; Feasibility studies; Letterboxes; Multiphases; Nonspeaking autism; Novel applications; Open-ended questions; Pass-through devices; User study; Augmented reality},
