@CONFERENCE{Kaushik2025,
	author = {Kaushik, Lakshaya and Singh, Ranjit P. and Singh, M.},
	title = {Comprehensive Analysis of Machine Learning Techniques in Autism Spectrum Disorder Detection},
	year = {2025},
	pages = {},
	doi = {10.1109/ICDCECE65353.2025.11036059},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009593000&doi=10.1109%2FICDCECE65353.2025.11036059&partnerID=40&md5=1c51b554375afd98575345385ff63f3f},
	affiliations = {Chandigarh University, Department of Computer Science and Engineering, Mohali, PB, India},
	abstract = {This review investigates the application of machine learning for (ASD) Autism Spectrum Disorder detection by reviewing existing models, discussing challenges, identifying future pathways for increasing detection and intervention services. We conducted a systematic review of studies from 2015 to 2024 that use ML techniques, including analysis of deep learning, traditional algorithms, and hybrid models, for the ASD detection, involving analyses of neuroimaging, behavioral, genetic, and physiological data. CNNs excel in neuroimaging, while RNNs aid time series behavioural data. Overall, the mutlimodal approach was more accurate that models reliant on single sources, ranging from 85% to 98% accurate. The two main issues were heterogeneity of data and limited feature selection. There is evidence in the literature, namely, that ML techniques may enhance ASD monitoring and identification. The future work should focus on creating datasets that consistently contain people from various backgrounds, creating interpretable machine learning models, and conducting clinical on these techniques. © 2025 IEEE.},
	author_keywords = {Autism Spectrum Disorder; Diagnosis; Early Detection; Ethical Considerations; Machine Learning; Neural Networks; Treatment},
