	title = {Development of a sensory stimulation device for tactile hyposensitivity rehabilitation},
	year = {2025},
	pages = {273 - 274},
	doi = {10.1109/ICCE-Taiwan66881.2025.11208037},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105022413818&doi=10.1109%2FICCE-Taiwan66881.2025.11208037&partnerID=40&md5=9e34d12889ad77cccc048eee8d38ffee},
	affiliations = {National Chin-Yi University of Technology, Department of Electronics Engineering, Taichung, Taiwan; Southern Taiwan University of Science and Technology, Department of Mechanical Engineering, Tainan, Taiwan; Hochschule Konstanz University of Applied Sciences, Department of Computer Science, Konstanz, Baden-Wurttemberg, Germany},
	abstract = {Tactile hyposensitivity, a sensory processing disorder characterized by the inability to differentiate tactile stimuli, frequently affects people with autism. However, despite the prevalence of the sense of touch in everyday life and the restorative potential of haptic feedback, the application of vibrotactile stimulation in the rehabilitation of tactile hyposensitivity is still underexplored. This study introduces Vibro, a portable companion device that utilizes sensory integration to steadily reduce tactile hyposensitivity over repeated use. Paired with its dedicated mobile application, the device delivers multimodal, integrating visual, audio, and tactile stimuli, and haptic feedback to the patient in the form of points, patterns, textures, music notes, and song frequencies. Facilitated by Vibro's testing module, which is loosely based on 2-point discrimination testing, initial experimental results from a seven-session patient user test demonstrated a statistically significant improvement in tactile sensitivity. A mean test score increase of 26.85 in 100-point tests was observed over the course of the initial user test, later validated using statistical analysis, suggesting its potential to enhance tactile perception and address tactile hyposensitivity. Future research should focus on upgrading the device to optimize user experience and efficacy while further evaluating the device to validate its impact. © 2025 IEEE.},
	author_keywords = {rehabilitation; Sensory integration; tactile hyposensitivity; vibrotactile stimulation},
