@CONFERENCE{Das2024,
	author = {Das, Shyamali and Chaudhury, Pamela and Tripathy, Hrudaya Kumar},
	title = {Classification of Autism Spectrum Disorder using CNN & Transfer Learning},
	year = {2024},
	pages = {},
	doi = {10.1109/ASSIC60049.2024.10507982},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85192986979&doi=10.1109%2FASSIC60049.2024.10507982&partnerID=40&md5=24611580d44ebc1a87ed418f799939f8},
	affiliations = {Sillicon Institute of Technology, Department of Computer Science and Engineering, Bhubaneswar, India; Kalinga Institute of Industrial Technology, Bhubaneswar, School of Computer Engineering, Bhubaneswar, OR, India},
	abstract = {Autism spectrum disorder (ASD) is a neurodevelopment condition that impacts a person's ability to communicate and interact socially. Diagnosing autism spectrum disorder (ASD) early and correctly is critical for providing appropriate help to those who need it. Transferring information or learned representations from one task or domain to another is possible using a computerized learning technique known as transfer learning. In this study, we proposed a method for classifying ASD using an Enhanced Layerwise Sequential Convolutional Neural Network (ELS-CNN) with transfer learning. Transfer learning involves leveraging pre-trained models on large-scale datasets used for the Kaggle platform and fine-tuning them for specific tasks. A dataset that tested these models was collected and consisted of 2,928 face images. These images are preprocessed using Adaptive Median Filtering to remove noise from an image and Histogram Equalization to improve image contrast. Otsu's Binary Threshold can be used for image segmentation. Extracting the features can be Principal Component Analysis (PCA) for image compression. We suggested the ELS-CNN algorithm, which has demonstrated good performance in a number of image identification applications. The output of the deep learning neural network models was assessed using common assessment measures like accuracy, precision, recall, and fl-score. The Enhanced Layerwise Sequential CNN algorithm achieved the highest accuracy. © 2024 IEEE.},
	author_keywords = {Adaptive Median Filtering; Autism Spectrum Disorder (ASD); Enhanced Layerwise Sequential Convolution Neural Network (ELS-CNN); Histogram Equalization; Otsu's Binary Threshold; Principal Component Analysis (PCA); Transfer Learning},
	keywords = {Adaptive filtering; Adaptive filters; Convolution; Convolutional neural networks; Deep learning; Diseases; Equalizers; Graphic methods; Image enhancement; Image segmentation; Large datasets; Learning systems; Median filters; Multilayer neural networks; Spectrum analysis; Adaptive median filtering; Autism spectrum disorder; Autism spectrum disorders; Binary threshold; Convolution neural network; Enhanced layerwise sequential convolution neural network; Histogram equalizations; Layer-wise; Otsu binary threshold; Principal component analyse; Principal-component analysis; Transfer learning; Principal component analysis},
