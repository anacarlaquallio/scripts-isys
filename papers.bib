	doi = {10.1109/EMCTECH63049.2024.10741698},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85211938444&doi=10.1109%2FEMCTECH63049.2024.10741698&partnerID=40&md5=104c5d6a61e6655c713a796308c8d92c},
	affiliations = {National Central University, Taoyuan, Taiwan; National Central University, Department of Finance, Taoyuan, Taiwan},
	abstract = {This study introduces an innovative methodology for assessing cloud service reliability by applying Almost Stochastic Dominance (ASD) theory to cloud server performance data. We analyze outage information from major cloud service providers, collected via the Cloud Harmony platform and Panopta's monitoring services, spanning July 2022 to February 2023. Our approach employs both Almost First-Order Stochastic Dominance (AFSD) and Almost Second-Order Stochastic Dominance (ASSD) methodologies, utilizing a multi-threshold framework with Îμ values of 0.0014, 0.0405, and 0.0732. This allows for a nuanced evaluation of service performance across varying levels of risk tolerance. Key findings reveal a highly competitive market at the strictest threshold, with performance disparities emerging as thresholds are relaxed. Notably, one provider demonstrates superior risk-adjusted performance under ASSD analysis. This research contributes a more robust and flexible analytical framework to the field, offering valuable insights for both consumers selecting cloud services and providers seeking to enhance their market position. Our findings underscore the importance of considering the full distribution of outcomes in cloud service evaluation, particularly for critical applications, and highlight the utility of ASD in capturing subtle performance differences often overlooked by traditional analysis methods. © 2024 IEEE.},
	author_keywords = {almost stochastic dominance; cloud outage; cloud service providers; performance evaluation; risk management},
