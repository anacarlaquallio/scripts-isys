@ARTICLE{Asif2023,
	author = {Asif, Muhammad and Martiniano, H. F.M.C. and Lamurias, Andre and Kausar, Samina and Couto, Francisco M.},
	title = {DGH-GO: dissecting the genetic heterogeneity of complex diseases using gene ontology},
	year = {2023},
	journal = {BMC Bioinformatics},
	volume = {24},
	number = {1},
	pages = {},
	doi = {10.1186/s12859-023-05290-4},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85153918433&doi=10.1186%2Fs12859-023-05290-4&partnerID=40&md5=142577ac6703a661af4b5729828880cb},
	affiliations = {Government College University Faisalabad, Department of Bioinformatics and Biotechnology, Faisalabad, Pakistan; Faculdade de Ciências da Universidade de Lisboa, Department of Computer Science, Lisbon, Lisboa, Portugal; Instituto Nacional de Saúde Dr. Ricardo Jorge, Lisbon, Portugal; Aalborg University, Aalborg, Nordjylland, Denmark; DeepOmicsVision, Marseille, France; Faculdade de Ciências da Universidade de Lisboa, BioISI - Instituto de Biosistemas e Ciências Integrativas, Lisbon, Lisboa, Portugal; Faculdade de Ciências e Tecnologia da Universidade Nova de Lisboa, Caparica, Setubal, Portugal},
	abstract = {Background: Complex diseases such as neurodevelopmental disorders (NDDs) exhibit multiple etiologies. The multi-etiological nature of complex-diseases emerges from distinct but functionally similar group of genes. Different diseases sharing genes of such groups show related clinical outcomes that further restrict our understanding of disease mechanisms, thus, limiting the applications of personalized medicine approaches to complex genetic disorders. Results: Here, we present an interactive and user-friendly application, called DGH-GO. DGH-GO allows biologists to dissect the genetic heterogeneity of complex diseases by stratifying the putative disease-causing genes into clusters that may contribute to distinct disease outcome development. It can also be used to study the shared etiology of complex-diseases. DGH-GO creates a semantic similarity matrix for the input genes by using Gene Ontology (GO). The resultant matrix can be visualized in 2D plots using different dimension reduction methods (T-SNE, Principal component analysis, umap and Principal coordinate analysis). In the next step, clusters of functionally similar genes are identified from genes functional similarities assessed through GO. This is achieved by employing four different clustering methods (K-means, Hierarchical, Fuzzy and PAM). The user may change the clustering parameters and explore their effect on stratification immediately. DGH-GO was applied to genes disrupted by rare genetic variants in Autism Spectrum Disorder (ASD) patients. The analysis confirmed the multi-etiological nature of ASD by identifying four clusters of genes that were enriched for distinct biological mechanisms and clinical outcome. In the second case study, the analysis of genes shared by different NDDs showed that genes causing multiple disorders tend to aggregate in similar clusters, indicating a possible shared etiology. Conclusion: DGH-GO is a user-friendly application that allows biologists to study the multi-etiological nature of complex diseases by dissecting their genetic heterogeneity. In summary, functional similarities, dimension reduction and clustering methods, coupled with interactive visualization and control over analysis allows biologists to explore and analyze their datasets without requiring expert knowledge on these methods. The source code of proposed application is available at https://github.com/Muh-Asif/DGH-GO © 2023, The Author(s).},
	author_keywords = {Dimension reduction; Functionally similarities; Gene ontology; Genetic heterogeneity; Neurodevelopmental disorders; Semantic similarity; Unsupervised learning},
	keywords = {Charge transfer; Cluster analysis; Diseases; Genes; K-means clustering; Principal component analysis; Reduction; Semantics; Visualization; Clinical outcome; Complex disease; Dimension reduction; Dimension reduction method; Functionally similarity; Gene ontology; Genetic heterogeneities; Neurodevelopmental disorder; Semantic similarity; User friendly; Gene Ontology; autism; gene ontology; genetic heterogeneity; genetics; human; software; Autism Spectrum Disorder; Genetic Heterogeneity; Humans; Software},
	correspondence_address = {M. Asif; Biomedical Data Science Lab, Department of Bioinformatics and Biotechnology, Government College University Faisalabad, Faisalabad, 38000, Pakistan; email: muhasif123@gmail.com; F.M. Couto; LASIGE, Departamento de Informática, Faculdade de Ciências, Universidade de Lisboa, Lisboa, Portugal; email: fjcouto@edu.ulisboa.pt},
	publisher = {BioMed Central Ltd},
	issn = {14712105},
