@CONFERENCE{Varshney2025155,
	author = {Varshney, Rajat Kishor and Katiyar, Alok and Johri, Prashant},
	title = {Hybrid CNN-RNN Models for Multimodal Analysis of Autism Spectrum Disorder Neuroimaging},
	year = {2025},
	pages = {155 - 160},
	doi = {10.1109/AUTOCOM64127.2025.10956945},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105003902284&doi=10.1109%2FAUTOCOM64127.2025.10956945&partnerID=40&md5=9aef59bcc543859d4e25773dd65343a6},
	affiliations = {Galgotias University, School of Computing Science & Engineering, Greater Noida, UP, India; Galgotias University, School of Computing Science & Engineering, Greater Noida, UP, India; Galgotias University, School of Computer Applications and Technology, Greater Noida, UP, India},
	abstract = {ASD is a developmental disorder in the neurological category and has numerous and diverse symptoms. Diagnosis is still problematic because symptoms of parkinsonism are diverse, and the dimensionality of the neuroimaging data is high. This paper presents a combination of CNN and RNN for classifying the ASD by analyzing multimodal neuroimaging data such as fMRI data, MRI data, and DTI data. The CNN component analyzes spatial characteristics of the neuroimaging data, and the RNN learns temporal patterns in fMRI series. Enhancements include a novel preprocessing step called 3D Brain Region Alignment (3D-BRA) as well as the 3D version of Adaptive Temporal, minimizing dimensionality through an innovative feature selection technique employing EN-CC. Predictive analysis with the hybrid model utilizes standard benchmark datasets such as ABIDE I, ABIDE II, HCP, and SFARI and records classification performances over 95 percentage. To enhance the interpretability of the model, the Grad-CAM algorithm is used, which marks specific regions of the brain important in the context of ASD. The proposed framework seems to possess considerable feasibility for enhancing the diagnosis of ASD and improving the understanding of its neural substrates, making the developed method highly advantageous for applications in neuroinformatics and clinical utility. © 2025 IEEE.},
	author_keywords = {Autism Spectrum Disorder; Brain Connectivity; Deep Learning; Feature Selection; fMRI; Hybrid CNN-RNN; Multimodal Analysis; Neuroimaging},
	keywords = {Brain mapping; Neurodegenerative diseases; Taxonomies; Autism spectrum disorders; Brain connectivity; Deep learning; Developmental disorders; Features selection; FMRI; fMRI data; Hybrid CNN-RNN; Multi-modal; Multimodal analysis},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {9798331542375},
	language = {English},
	abbrev_source_title = {Int. Conf. Autom. Comput., AUTOCOM},
	type = {Conference paper},
	publication_stage = {Final},
