@ARTICLE{Hening Darmasti2023546,
	author = {Hening Darmasti, Aulia and Pinkwart, Niels and Zender, Raphael},
	title = {User Experience Evaluation in Virtual Reality for Autism: A Systematic Literature Review},
	year = {2023},
	journal = {Lecture Notes in Computer Science},
	volume = {14020 LNCS},
	pages = {546 - 568},
	doi = {10.1007/978-3-031-35681-0_36},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85169025341&doi=10.1007%2F978-3-031-35681-0_36&partnerID=40&md5=02601556468726b17b656e27cb95e8dd},
	affiliations = {Humboldt-Universität zu Berlin, Department of Computer Science, Berlin, Germany},
	abstract = {Virtual reality (VR) used for people with autism spectrum disorder (ASD) is gaining a place among researchers lately. The rich interactivity provided by VR makes it a powerful tool for various purposes, one of which is to support interventions for people with ASD. Since people with ASD have a different sensory experience, the user experience (UX) within VR applications for ASD becomes a crucial aspect. There have been past literature reviews of VR applications for ASD. However, to the best of our knowledge, there is hardly one that focuses on the methods used in evaluating the users’ experience towards interaction techniques or interface elements incorporated in various VR applications. In this review, 24 studies met predetermined PICo (Population, Interest, Context) criteria from the search based on three relevant databases, namely Pubmed NCBI, Dimensions.ai, and IEEE Xplore. Direct examination from observers appears as the most popular method used to assess experiences of people with ASD in using VR and followed by self-report questionnaire method. In addition, although all relevant literatures mentioned their UX evaluation method, only a few studies whose evaluation is relevantly subjected towards their interaction techniques or user interface elements. This review is expected to provide insights and considerations in designing UX evaluation method for VR applications for people with ASD in the future. © 2023, The Author(s), under exclusive license to Springer Nature Switzerland AG.},
	author_keywords = {Autistic spectrum disorder; Interaction technique; User experience; User interface elements; Virtual reality},
	keywords = {Diseases; Virtual reality; Autism spectrum disorders; Autistic spectrum disorders; Evaluation methods; Interaction techniques; Interactivity; Interface elements; Systematic literature review; User experience evaluations; User interface element; Users' experiences; User interfaces},
	correspondence_address = {A. Hening Darmasti; Department of Computer Science, Humboldt University of Berlin, Berlin, Germany; email: darmasta@hu-berlin.de},
	editor = {Antona, M. and Stephanidis, C.},
	publisher = {Springer Science and Business Media Deutschland GmbH},
	issn = {03029743},
	isbn = {9789819698936; 9789819698042; 9789819698110; 9789819698905; 9783032004949; 9789819512324; 9783032026019; 9783032008909; 9783031915802; 9789819698141},
	language = {English},
