	year = {2025},
	journal = {IEEE Access},
	volume = {13},
	pages = {121512 - 121532},
	doi = {10.1109/ACCESS.2025.3586314},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010197977&doi=10.1109%2FACCESS.2025.3586314&partnerID=40&md5=d0b7a2055c83e203da4faa222c0a4b21},
	affiliations = {Rajshahi University of Engineering and Technology, Department of Electrical & Computer Engineering, Rajshahi, Bangladesh; Department of Electrical Engineering, College of Engineering, Qatar University, Doha, Qatar; Universiti Kebangsaan Malaysia, Department of Physiology, Bangi, Selangor, Malaysia},
	abstract = {Autism Spectrum Disorder (ASD) is a genetic and neurological condition that leads to difficulties in communication and social interaction. The global concern associated with ASD diagnosis is increasing at a rapid rate due to its significant impact on quality of life. Early identification of ASD can significantly support timely intervention and treatment planning. While research in ASD diagnosis is evolving through the application of machine learning (ML) techniques, practical implementation in clinical settings has not progressed at the same pace. Although theoretical studies have demonstrated improved ML performance, they have not gained much interest among clinicians due to a lack of explainability. This study focuses on optimizing and comparing various machine learning models for ASD diagnosis, while incorporating explainable AI techniques to ensure model transparency and interpretability. The paper uses naive Bayes, Support Vector Machine (SVM), and Random Forest (RF) as classifiers after careful investigation. Three different publicly available datasets have been used based on the age group to create the best predicting model for each case. After handling missing values, balancing the dataset, and analyzing the classifier’s performance, it is found that tree-based algorithms, particularly RF, perform better for all the datasets. The RF model achieved up to 99% balanced accuracy on the adult dataset, with similarly strong performance on the children and adolescent datasets using five-fold cross-validation (CV). SHAP are also illustrated to improve model interpretability by highlighting the most influential features, thereby aiding physician understanding. The novelty of this work lies in the integration of explainable AI with robust preprocessing and age-specific modeling across multiple ASD datasets, addressing both diagnostic accuracy and clinical interpretability. It can be considered that the suggested method can efficiently diagnose ASD at a very early stage and enhance the understanding of ASD diagnosis clinically. © 2013 IEEE.},
	author_keywords = {artificial intelligence (AI); Autism spectrum disorder (ASD); explainable AI; machine learning (ML)},
	keywords = {Classification (of information); Classifiers; Computer aided diagnosis; Decision trees; Diseases; Forestry; Learning systems; Random forests; Support vector machines; Artificial intelligence; Autism spectrum disorder; Autism spectrum disorders; Condition; Explainable artificial intelligence; Interpretability; Machine learning; Machine-learning; Performance; Clinical research},
