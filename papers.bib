@CONFERENCE{Arathi2024,
	author = {Arathi, T. S. and Sasikumar, Samyukths and Mahesh, A. S.},
	title = {Predictive Analysis of Autism Spectrum Disorder using Machine Learning Techniques∗},
	year = {2024},
	pages = {},
	doi = {10.1109/CONIT61985.2024.10626711},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85202744003&doi=10.1109%2FCONIT61985.2024.10626711&partnerID=40&md5=094315202b7fc51f17110f0cb45d6b65},
	affiliations = {Amrita Vishwa Vidyapeetham University, Kochi, Department of CS & IT, Kochi, KL, India},
	abstract = {This thesis examines autism spectrum disorder (ASD) forecast with advanced machine learning methods, specifically gradient enhancement models, neural networks, and a hybrid model combining them. The overall goal is to increase prediction accuracy in Identifying ASD, to facilitate early intervention and support. Our experimental findings reveal that by exploiting the strengths of gradient enhancement and neural network, the combined model achieved the best overall accuracy of 86.875% notably that is, both individual models showed adequate cross-validation accuracy, with gradient enhancement 84. 125 % and neural network 85. 125 %. The findings demonstrate how well machine learning techniques work to comprehend the intricacy of 19th-century ASD research data. Additionally, demonstrating the synergistic benefits of model fusion, the combined model performs better than the gradient boosting model alone. Our study confirms that the hybrid approach preserves the robustness of the individual models and improves accuracy is increased. As this model continues to be refined, it is poised to increase its application in ASD research, providing healthcare professionals and caregivers with a powerful tool to identify and support individuals across the autism spectrum. The consistent performance of the combined and individual models further highlights the consistency of the predictive power. This study shows the promise of machine learning integrated approaches in healthcare and offers a strong platform for future research in ASD prediction. © 2024 IEEE.},
	author_keywords = {accuracy score; Autism spectrum disorder (ASD); Gradient Boosting; machine learning; Neural network},
	keywords = {Contrastive Learning; Diseases; Federated learning; Neural network models; Prediction models; Accuracy score; Autism spectrum disorder; Autism spectrum disorders; Combined modeling; Gradient boosting; Individual modeling; Machine learning methods; Machine learning techniques; Machine-learning; Neural-networks; Adversarial machine learning},
