	doi = {10.1145/3716553.3757091},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105022241492&doi=10.1145%2F3716553.3757091&partnerID=40&md5=158a9a23f2b26dcd06a23b6f9b290b1d},
	affiliations = {Marriotts Ridge High School, Marriottsville, MD, United States},
	abstract = {Autism Spectrum Disorder (ASD) affects more than 75 million people worldwide. However, scalable support for practicing everyday conversation is scarce: Low-cost activities such as story reading yield limited improvement. At the same time, effective role-play therapy demands expensive, in-person sessions with specialists. SocialWise bridges this gap through a browser-based application that pairs LLM conversational agents with a therapeutic retrieval augmented generation (RAG) knowledge base. Users select a scenario (e.g., ordering food, joining a group), interact by text or voice, and receive instant, structured feedback on tone, engagement, and alternative phrasing. The SocialWise prototype, implemented with Streamlit, LangChain, and ChromaDB, runs on any computer with internet access, and demonstrates how recent advances in LLM can provide evidence-based, on-demand communication coaching for individuals with ASD. © 2025 Copyright is held by the owner/author(s). Publication rights licensed to ACM.},
	author_keywords = {SocialWise; LLM; Agents; Conversation Therapy; Autism Spectrum Disorder},
	keywords = {Human computer interaction; Human engineering; Interactive computer systems; Social sciences computing; Agent;; Autism spectrum disorders; Browser-based application; Communication skills; Conversation therapy;; Conversational agents; LLM;; Low-costs; Role-plays; Socialwise;; Knowledge based systems},
