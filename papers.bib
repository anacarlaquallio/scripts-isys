	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 4}
}

@CONFERENCE{Xu2024,
	author = {Xu, Claire},
	title = {Exploring AI-Based Reciprocal Eye Engagement Training to Enhance Dyadic Behavior in Individuals With Alexithymia},
	year = {2024},
	pages = {},
	doi = {10.1109/ICMI60790.2024.10586064},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85199458639&doi=10.1109%2FICMI60790.2024.10586064&partnerID=40&md5=3cb3e551866604ad7ae483f52a8b4203},
	affiliations = {The Harker School, San Jose, CA, United States},
	abstract = {The significance of socio-emotional difficulties in various neurodivergent and mental health conditions has led to an investigation into the co-occurrence of alexithymia in autism spectrum disorder (ASD), depression, anxiety, and schizophrenia. The study aimed to improve reciprocal eye engagement in individuals with Alexithymia, and hence enhance dyadic behavior and mutual understanding. This study introduced an innovative individual-paced progressive training involved 4 levels from cartoon faces, still facial images, self-videos, to trainer-led reciprocal eye engagement video sessions. The computer vision based real-time feedback on gaze dwell time, eye movement, blink rates, and reciprocal eye engagement achieved higher spatial and temporal resolution. 10 subjects, ages ranging from 7 to 10, were recruited who have clinical assessment of ASD with level 1 support and were also assessed with alexithymia using Children's alexithymia Measure (CAM). 6 subjects made statistically significant improvement over the self-paced training period between 4-8 weeks with p-value<5% for both gaze dwell time and number of reciprocal eye engagement, 3 subjects showed slight improvements, and 1 subject showed no improvement. Notably, this real-time AI-based annotation on screen reinforced the association between eye engagement and positive social interactions which is missing in alexithymia individuals. Furthermore, the trainer-led synchronous training, level 4 specifically, enhanced dyadic behavior by emulating real-life interactions, led to increased engagement, confidence, and skill retention. The life video cameras transcended the physical boundaries. This research also underscored its potential applications in human-computer interactions and future direction on emotion recognition to promote neurodivergent relationships and inclusive society. © 2024 IEEE.},
	author_keywords = {alexithymia; autism spectrum disorder (ASD); computer vision; dyadic behavior; eye gaze; reciprocal eye contact},
	keywords = {Association reactions; Diseases; Emotion Recognition; Eye movements; Human computer interaction; Video cameras; Alexithymia; Autism spectrum disorder; Autism spectrum disorders; Dwell time; Dyadic behavior; Eye-contact; Eye-gaze; Health condition; Mental health; Reciprocal eye contact; Computer vision},
