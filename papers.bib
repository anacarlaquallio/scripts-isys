@CONFERENCE{Bogdanović2023,
	author = {Bogdanović, Aleksa and Gavrovska, Ana M.},
	title = {'HelpMe': Mobile Application for Emergency Calls},
	year = {2023},
	pages = {},
	doi = {10.1109/TELFOR59449.2023.10372642},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85183457044&doi=10.1109%2FTELFOR59449.2023.10372642&partnerID=40&md5=e51cc0300e8c593d3c1ef85850a7ff22},
	affiliations = {School of Electrical Engineering, Belgrade, Serbia},
	abstract = {The advent of smartphones and technological advancements has greatly enhanced accessibility to emergency audio calls, significantly improving the lives of people. Nowadays, widespread mobile infrastructure and smartphones have made it effortless for individuals to access the internet and make emergency calls in various critical situations, such as accidents, health emergencies, or fires. However, the exclusive reliance on audio calls to reach the police, emergency medical services, and firefighters often excludes a significant portion of the population, including those who are deaf, hard of hearing, have speech impairments, severe disabilities, and autistic individuals. This paper introduces the 'HelpMe' application prototype, designed to facilitate access and communication with emergency services in specific scenarios. This application not only addresses the needs of those who cannot make audio calls, but also offers improved responsiveness to emergency situations for those who can use traditional phone calls. © 2023 IEEE.},
	author_keywords = {aid; Android; emergency calls; functionalities; Mobile application; services},
