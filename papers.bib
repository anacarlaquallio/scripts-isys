	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85211185885&doi=10.1109%2FICCCNT61001.2024.10724428&partnerID=40&md5=3064cab8b131431aa733ba07be7a1372},
	affiliations = {Kerala University of Digital Sciences, Innovation and Technology, School of Computer Science and Engineering, Thiruvananthapuram, KL, India},
	abstract = {This research introduces an approach to functional Magnetic Resonance Imaging (fMRI) analysis, focusing on Nonlinear Functional Connectivity (NFC). Traditional linear correlation methods in fMRI studies may fail to capture the intricate nonlinear relationships inherent in neural dynamics. By employing a kernel function, we explore these nonlinear dependencies, transforming the data to reveal hidden patterns. Our methodology delves into the nonlinearity of brain images using the kernel function, encompassing preprocessing of fMRI data, generated a brain graph, extraction of relevant graph features, and application of kernel techniques to quantify the communication and interaction between brain regions. The binary classes of Autism Brain Imaging Data Exchange (ABIDE) are used for the experimental analysis. The experiment showed that this kernel-based strategy, which may be overlooked by conventional linear methods, reveals unique and biologically meaningful connection patterns. © 2024 IEEE.},
