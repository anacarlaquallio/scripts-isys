@CONFERENCE{Perillo202458,
	author = {Perillo, Francesca Pia and Romano, Marco and Vitiello, Giuliana},
	title = {Social Robots Design to improve Social Skills in Autism Spectrum Disorder},
	year = {2024},
	journal = {CEUR Workshop Proceedings},
	volume = {3751},
	pages = {58 - 64},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85203828735&partnerID=40&md5=adc13ed64ebb7444420c2e6f7a37110f},
	affiliations = {Università degli Studi di Salerno, Salerno, SA, Italy; Universita degli Studi Internazionali di Roma, Rome, Lazio, Italy},
	abstract = {The incorporation of social robots signifies a notable advancement in the field of robotics, allowing machines to interact with humans not merely on a functional level, but also in emotional and social dimensions. Equipped with artificial intelligence, sensors, and communication capabilities, these robots possess the capacity to identify emotions, respond to social cues, and adjust their behavior accordingly. The advent of social robots marks a substantial transformation in human-robot interaction, emphasizing emotional connections and social engagement as mechanisms to bridge the gap between humans and machines. In this study, we demonstrate that within the domain of autism therapy, the integration of social robots—QTrobot, NAO, and Pepper—has yielded promising outcomes. Each robot exhibits distinctive features tailored to specific therapeutic requirements. Our conclusions offer guidelines for the selection of the most suitable robot, considering individual strengths and functionalities, within the context of autism therapy. It is important, however, to acknowledge that despite the potential therapeutic applications for individuals with autism, social robots do not constitute a comprehensive solution. Instead, they present supplementary avenues for engagement and learning, acting in tandem with the efforts of human therapists. © 2024 Copyright for this paper by its authors.},
	author_keywords = {ASD; children; Social Robotics},
	keywords = {Diseases; Economic and social effects; Industrial robots; Microrobots; Robot applications; Robot learning; ASD; Autism spectrum disorders; Autism therapies; Child; Emotional dimensions; Functional levels; Robot designs; Social robotics; Social robots; Social skills},
