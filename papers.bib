}

@CONFERENCE{Das2023,
	author = {Das, Madhuparna and Mahadevappa, Manjunatha},
	title = {Enhancing ASD Cognitive Assessment with P300 Classification using EMD-based qEEG Wavelet Features},
	year = {2023},
	pages = {},
	doi = {10.1109/CERA59325.2023.10455596},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85187792833&doi=10.1109%2FCERA59325.2023.10455596&partnerID=40&md5=4a65c88cec909369f1f75ce06f2d5bc0},
	affiliations = {Indian Institute of Technology Kharagpur, School of Medical Science and Technology, Kharagpur, WB, India},
	abstract = {Individuals with Autism Spectrum Disorder (ASD) often face challenges in effective communication due to deficiencies in their joint attention skills. Brain-Computer Interface (BCI) systems based on the P300 Electroencephalogram (EEG) signal has shown promising results in neuro-rehabilitation training for individuals with Autism spectrum disorder(ASD), helping them overcome these communication barriers. However, detecting the P300 signal in ASD is particularly difficult due to its noisy nature, lower amplitude, and higher latency compared to other individuals. In this paper, we propose a novel application of the Empirical mode decomposition (EMD) using the Hilbert Huang transform to identify the P300 signal in a BCI system involving ASD subjects. Further, the optimized mode was selected and utilized and the qEEG fused time-frequency domain wavelet features were extracted for each selected mode of each individual channel. To address the class imbalance issue in the dataset, To handle imbalanced data, we applied SMOTE for data augmentation, and for optimized feature selection, we used PCA. We conducted a comparative classification analysis using five popular machine-learning classifiers. Among the classifiers, Random Forest outperformed the others, achieving 93% accuracy. These results demonstrate the effectiveness of our approach in enhancing P300 signal identification for joint attention-based cognitive task classification for individuals with ASD, surpassing state-of-the-art methods. © 2023 IEEE.},
	author_keywords = {Autism Spectrum Disorder; BCI P300 signal; DWT; EEG; qEEG},
	keywords = {Biomedical signal processing; Brain computer interface; Diseases; Empirical mode decomposition; Feature Selection; Frequency domain analysis; Hilbert-Huang transform; Learning systems; Autism spectrum disorders; Brain-computer interface p300 signal; Cognitive assessments; DWT; Effective communication; Empirical Mode Decomposition; Interface system; Joint attention; QEEG; Wavelet features; Electroencephalography},
	correspondence_address = {M. Das; Indian Institute of Technology, School of Medical Science and Technology, Kharagpur, India; email: madhuparnadas01@kgpian.iitkgp.ac.in},
